<Window x:Class="Emutastic.Views.FriendDetailWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Friend Profile"
        Width="900" Height="700"
        MinWidth="640" MinHeight="480"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Border Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderNormalBrush}"
            BorderThickness="1"
            CornerRadius="6">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Themed title bar (drag-to-move + close) -->
        <Grid Grid.Row="0"
              Background="{DynamicResource BgSecondaryBrush}"
              Height="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Name="TitleBarText"
                       Text="Friend Profile"
                       FontFamily="{DynamicResource PrimaryFont}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"/>
            <Button Grid.Column="1"
                    Name="TitleBarCloseBtn"
                    Content="✕"
                    Width="44" Height="36"
                    Background="Transparent"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    BorderThickness="0"
                    FontSize="12"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Cursor="Hand"
                    Click="TitleBarCloseBtn_Click"/>
        </Grid>

        <!-- Header: avatar + identity + stats glance -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,20,24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="80" Height="80"
                        CornerRadius="40"
                        Background="{DynamicResource BgTertiaryBrush}"
                        ClipToBounds="True">
                    <Image Name="HeaderAvatar" Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,16,0" VerticalAlignment="Center">
                    <TextBlock Name="HeaderUsername"
                               FontFamily="{DynamicResource PrimaryFont}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="—"/>
                    <TextBlock Name="HeaderMotto"
                               FontFamily="{DynamicResource PrimaryFont}"
                               FontSize="12"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0"/>
                    <TextBlock Name="HeaderMemberSince"
                               FontFamily="{DynamicResource PrimaryFont}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,4,0,0"/>

                    <!-- Per-friend notification toggle. Click the row to mute /
                         unmute achievement + leaderboard toasts for this user.
                         Custom template strips WPF's default light-blue hover
                         background. Hover affordance is the bell turning gold +
                         a small ringing wobble (handled in code-behind on
                         MouseEnter/MouseLeave so the animation can use the
                         theme's existing Foreground brush as the "off" state). -->
                    <Button Name="HeaderToastsToggle"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Cursor="Hand"
                            Click="HeaderToastsToggle_Click">
                        <StackPanel Orientation="Horizontal">
                            <!-- Tintable vector bell (upstream's PackIcon Bell/BellOff) — geometry set
                                 in code-behind; pivot near the crown for the hover ring animation. -->
                            <Path Name="HeaderToastsIcon" Width="14" Height="14" Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource TextSecondaryBrush}"
                                  RenderTransformOrigin="50%,15%"/>
                            <TextBlock Name="HeaderToastsLabel"
                                       Text="Get notifications about this user"
                                       FontFamily="{DynamicResource PrimaryFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,18,0">
                        <TextBlock Name="HeaderHardcorePoints"
                                   FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Right"
                                   Text="—"/>
                        <TextBlock Text="POINTS"
                                   FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Name="HeaderSoftcorePoints"
                                   FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right"
                                   Text="—"/>
                        <TextBlock Text="SOFTCORE"
                                   FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Inner TabControl: Overview / Recent / Compare / Leaderboards -->
        <TabControl Grid.Row="2"
                    Name="DetailTabs"
                    Margin="24,12,24,24"
                    Background="Transparent"
                    BorderThickness="0">

            <TabItem Header="Overview" Name="OverviewTab">
                <ScrollViewer
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Name="OverviewPanel" Margin="0,12,0,0">

                        <!-- Stats grid -->
                        <TextBlock Text="STATS"
                                   FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="2,0,0,8"/>
                        <Border Background="{DynamicResource BgSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="18,14,18,14"
                                Margin="0,0,0,18">
                            <UniformGrid Name="StatsGrid" Columns="4"/>
                        </Border>

                        <!-- Currently / last played -->
                        <TextBlock Text="LAST PLAYED"
                                   FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="2,0,0,8"/>
                        <Border Name="RecentlyPlayedCard"
                                Background="{DynamicResource BgSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,12,14,8"
                                Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Name="RecentlyPlayedHeader"
                                           Text="RECENTLY PLAYED"
                                           FontFamily="{DynamicResource PrimaryFont}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,8"/>
                                <ItemsControl Name="RecentlyPlayedItems"/>
                                <TextBlock Name="RecentlyPlayedEmpty"
                                           Text="No recently played games."
                                           FontFamily="{DynamicResource PrimaryFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,4,0,8"
                                           IsVisible="False"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Name="OverviewStatusText"
                                   FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,24,0,0"
                                   IsVisible="False"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Recent" Name="RecentTab">
                <ScrollViewer
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,12,0,0">
                        <Border Background="{DynamicResource BgSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="0">
                            <StackPanel>
                                <ItemsControl Name="RecentUnlocksList"/>
                                <TextBlock Name="RecentEmptyText"
                                           Text="No recent unlocks in the last 24 hours."
                                           FontFamily="{DynamicResource PrimaryFont}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextAlignment="Center"
                                           Padding="16,28,16,28"
                                           IsVisible="False"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Compare" Name="CompareTab">
                <ScrollViewer
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,12,0,0">

                        <!-- Side-by-side stats header -->
                        <Border Background="{DynamicResource BgSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="18,14,18,14"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="YOU"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Name="CompareYouPoints"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="0,2,0,0"
                                               Text="—"/>
                                    <TextBlock Name="CompareYouCounts"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,2,0,0"
                                               Text="—"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,20,0">
                                    <TextBlock Name="CompareDeltaPoints"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               Text="—"/>
                                    <TextBlock Name="CompareDeltaCounts"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,0"
                                               Text="—"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                    <TextBlock Name="CompareThemLabel"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Right"
                                               Text="—"/>
                                    <TextBlock Name="CompareThemPoints"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Right"
                                               Margin="0,2,0,0"
                                               Text="—"/>
                                    <TextBlock Name="CompareThemCounts"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Right"
                                               Margin="0,2,0,0"
                                               Text="—"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Filter / sort strip -->
                        <Grid Margin="2,0,2,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Name="CompareHideIdentical"
                                      Grid.Column="0"
                                      Content="Hide games with the same progress"
                                      FontFamily="{DynamicResource PrimaryFont}"
                                      FontSize="11"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      VerticalAlignment="Center"
                                      IsChecked="True"
                                      IsCheckedChanged="CompareFilter_Changed"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Sort:"
                                           FontFamily="{DynamicResource PrimaryFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <ComboBox Name="CompareSortBox"
                                          Theme="{StaticResource DarkComboBox}"
                                          Width="160"
                                          FontSize="11"
                                          SelectedIndex="0"
                                          SelectionChanged="CompareFilter_Changed">
                                    <ComboBoxItem Content="Biggest gap (catch up)"/>
                                    <ComboBoxItem Content="Biggest gap (you're ahead)"/>
                                    <ComboBoxItem Content="My progress (high → low)"/>
                                    <ComboBoxItem Content="Their progress (high → low)"/>
                                    <ComboBoxItem Content="Title (A → Z)"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Common games list -->
                        <Border Background="{DynamicResource BgSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="0">
                            <StackPanel>
                                <ItemsControl Name="CompareGamesList"/>
                                <TextBlock Name="CompareStatus"
                                           Text="Loading comparison…"
                                           FontFamily="{DynamicResource PrimaryFont}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextAlignment="Center"
                                           Padding="16,28,16,28"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Leaderboards" Name="LeaderboardsTab">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Game picker: only games BOTH of you have touched -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Game:"
                                   FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="2,0,8,0"/>
                        <ComboBox Name="LbGamePicker"
                                  Theme="{StaticResource DarkComboBox}"
                                  Grid.Column="1"
                                  FontSize="12"
                                  SelectionChanged="LbGamePicker_SelectionChanged"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Border Background="{DynamicResource BgSecondaryBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="0">
                                <StackPanel>
                                    <ItemsControl Name="LbBoardsList"/>
                                    <TextBlock Name="LbStatus"
                                               Text="Pick a common game to compare leaderboards."
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Padding="16,28,16,28"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
    </Border>
</Window>
