<Window xmlns="https://github.com/avaloniaui"
        Icon="/Assets/banners and icons/emutastic-logo.png"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pe="using:Emutastic.Views.PauseEffects"
        x:Class="Emutastic.Views.PreferencesWindow"
        x:CompileBindings="False"
        Title="Preferences"
        Height="700" Width="1100"
        MinHeight="520" MinWidth="820"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowDecorations="None"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- Nav pill (RadioButton): transparent → hover surface → checked surface + bright text. -->
        <ControlTheme x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{DynamicResource PrimaryFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="bd" Background="Transparent" CornerRadius="8"
                            Padding="{TemplateBinding Padding}" VerticalAlignment="Center" Height="32">
                        <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#bd">
                <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
            </Style>
            <Style Selector="^:checked">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            </Style>
            <Style Selector="^:checked /template/ Border#bd">
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            </Style>
        </ControlTheme>

        <!-- Section label above a setting. -->
        <ControlTheme x:Key="PrefLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource PrimaryFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </ControlTheme>

        <!-- Charcoal primary action button. -->
        <ControlTheme x:Key="PrefActionBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PlayBtnBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{DynamicResource PrimaryFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#bd"><Setter Property="Background" Value="{DynamicResource PillHoverBgBrush}"/></Style>
        </ControlTheme>

        <!-- Secondary (outlined) button. -->
        <ControlTheme x:Key="PrefSecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgQuaternaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderNormalBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="{DynamicResource PrimaryFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#bd"><Setter Property="Background" Value="{DynamicResource BgTertiaryBrush}"/></Style>
        </ControlTheme>

        <!-- Traffic-light window button (round). -->
        <ControlTheme x:Key="WinBtn" TargetType="Button">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" CornerRadius="7"/>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover"><Setter Property="Opacity" Value="0.8"/></Style>
        </ControlTheme>
    </Window.Resources>

    <!-- Root card (custom chrome → soft window shadow) -->
    <Border x:Name="OuterBorder" Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderNormalBrush}" BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" OffsetX="0" OffsetY="0" Opacity="0.6" Color="{DynamicResource ShadowColor}"/>
        </Border.Effect>

        <!-- Inner clip border so child content respects the rounded corners (matches upstream). -->
        <Border x:Name="InnerClip" CornerRadius="10" ClipToBounds="True">
        <Grid Name="RootGrid" RowDefinitions="38,46,*" ClipToBounds="True">

            <!-- ═══ TITLE BAR ═══ -->
            <Grid Name="CustomTitleBar" Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                  ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Preferences" FontSize="13" FontWeight="SemiBold"
                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="{DynamicResource WinBtnStripVAlign}"
                            Margin="{DynamicResource WinBtnStripMargin}"
                            Spacing="{DynamicResource WinBtnStripSpacing}">
                    <Button Name="MinimizeButton" Theme="{DynamicResource ActiveMinButton}" ToolTip.Tip="Minimize"/>
                    <Button Name="MaximizeButton" Theme="{DynamicResource ActiveMaxButton}" ToolTip.Tip="Maximize"/>
                    <Button Name="CloseButton" Theme="{DynamicResource ActiveCloseButton}" ToolTip.Tip="Close"/>
                </StackPanel>
            </Grid>

            <!-- ═══ NAV BAR ═══ -->
            <Border Grid.Row="1" Background="{DynamicResource BorderSubtleBrush}"
                    BorderBrush="{DynamicResource BorderNormalBrush}" BorderThickness="0,0,0,1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <RadioButton Name="NavControls" Content="Controls" GroupName="NavGroup" IsChecked="True" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavSystemFiles" Content="System Files" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavCores" Content="Cores / Extras" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavCoreOptions" Content="Core Options" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavLibrary" Content="Library" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavTheme" Content="Theme" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavSnaps" Content="Snaps" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavAchievements" Content="Achievements" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavMedia" Content="Media" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavBackups" Content="Backups" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavEmuTv" Content="EmuTV" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                        <RadioButton Name="NavAbout" Content="About" GroupName="NavGroup" Theme="{StaticResource NavBtn}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══ CONTENT (one panel visible at a time; filled per U5 sub-splinter) ═══ -->
            <Grid Grid.Row="2">
                <Grid Name="PanelControls" ColumnDefinitions="3*,310">
                    <!-- LEFT: controller diagram -->
                    <Border Grid.Column="0" Background="{DynamicResource ContentBgBrush}"
                            BorderBrush="{DynamicResource BorderNormalBrush}" BorderThickness="0,0,1,0">
                        <Image Name="ControllerImage" Stretch="Uniform" Margin="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- RIGHT: mapping controls -->
                    <Grid Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}" RowDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Row="0" Margin="16,14,16,0">
                            <TextBlock Text="SYSTEM" Theme="{StaticResource PrefLabel}" Margin="0,0,0,4"/>
                            <ComboBox Name="SystemComboBox" Theme="{StaticResource DarkComboBox}" HorizontalAlignment="Stretch"/>
                            <TextBlock Text="PLAYER" Theme="{StaticResource PrefLabel}"/>
                            <ComboBox Name="PlayerComboBox" Theme="{StaticResource DarkComboBox}" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Player 1"/><ComboBoxItem Content="Player 2"/>
                                <ComboBoxItem Content="Player 3"/><ComboBoxItem Content="Player 4"/>
                            </ComboBox>
                            <TextBlock Text="CONTROLLER SLOT" Theme="{StaticResource PrefLabel}"/>
                            <ComboBox Name="ControllerSlotComboBox" Theme="{StaticResource DarkComboBox}" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Default"/><ComboBoxItem Content="Controller 1"/><ComboBoxItem Content="Controller 2"/>
                                <ComboBoxItem Content="Controller 3"/><ComboBoxItem Content="Controller 4"/>
                            </ComboBox>
                            <TextBlock Text="GAMEPLAY BUTTONS" Theme="{StaticResource PrefLabel}" Margin="0,16,0,6"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,2"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" Margin="16,4,4,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Name="ButtonsPanel" Margin="0,0,12,8"/>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="{DynamicResource BgPrimaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                BorderThickness="0,1,0,0" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="INPUT DEVICE" Theme="{StaticResource PrefLabel}" Margin="0,0,0,4"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <ComboBox Name="InputDeviceComboBox" Grid.Column="0" Theme="{StaticResource DarkComboBox}" HorizontalAlignment="Stretch"/>
                                    <Button Name="RefreshDevicesBtn" Grid.Column="1" Content="↻" Theme="{StaticResource PrefSecondaryBtn}"
                                            Padding="10,6" FontSize="14" Margin="6,0,0,0" ToolTip.Tip="Refresh devices"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
                                    <Button Name="ResetDefaultsBtn" Content="Reset Defaults" Theme="{StaticResource PrefSecondaryBtn}"/>
                                    <Button Name="SaveControlsBtn" Content="Save" Theme="{StaticResource PrefActionBtn}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
                <Grid Name="PanelSystemFiles" IsVisible="False">
                    <ScrollViewer Margin="24,16,24,16" VerticalScrollBarVisibility="Auto">
                        <StackPanel Name="BiosPanel"/>
                    </ScrollViewer>
                </Grid>
                <Grid Name="PanelCores" IsVisible="False">
                    <ScrollViewer Margin="24,16,24,16" VerticalScrollBarVisibility="Auto">
                        <StackPanel Name="CoresListPanel"/>
                    </ScrollViewer>
                </Grid>
                <Grid Name="PanelCoreOptions" IsVisible="False" ColumnDefinitions="200,*">
                    <!-- Left: cores with a saved schema -->
                    <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}"
                            BorderBrush="{DynamicResource BorderNormalBrush}" BorderThickness="0,0,1,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="CORES" FontSize="10" FontWeight="SemiBold"
                                       FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextMutedBrush}" Margin="14,14,14,8"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Name="CoreOptionsCoreList" Margin="6,0,6,8"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Right: options for the selected core -->
                    <Grid Grid.Column="1" RowDefinitions="*,Auto">
                        <ScrollViewer Grid.Row="0" Margin="24,16,24,8" VerticalScrollBarVisibility="Auto">
                            <StackPanel Name="CoreOptionsOptionList"/>
                        </ScrollViewer>
                        <Border Grid.Row="1" Background="{DynamicResource BgSecondaryBrush}"
                                BorderBrush="{DynamicResource BorderNormalBrush}" BorderThickness="0,1,0,0" Padding="24,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Name="CoreOptionsResetBtn" Content="Reset to Defaults" Theme="{StaticResource PrefSecondaryBtn}" IsEnabled="False"/>
                                <Button Name="CoreOptionsSaveBtn" Content="Save" Theme="{StaticResource PrefActionBtn}" IsEnabled="False"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
                <Grid Name="PanelLibrary" IsVisible="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="32,24,32,24" MaxWidth="600" HorizontalAlignment="Left">
                            <TextBlock Text="DATA DIRECTORY" Theme="{StaticResource PrefLabel}"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="All app data (database, saves, artwork, snaps, screenshots) is stored here. Configured on first launch."/>
                            <Border Background="{DynamicResource BgTertiaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="10,8">
                                <TextBlock Name="DataDirPathText" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                           FontFamily="{DynamicResource PrimaryFont}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </Border>

                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,24,0,16"/>

                            <TextBlock Text="GAME LIBRARY FOLDER" Theme="{StaticResource PrefLabel}"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="A folder where imported games can be copied. If none is set (or you keep games in place below), your ROMs are never moved."/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Border Grid.Column="0" Background="{DynamicResource BgTertiaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10,8">
                                    <TextBlock Name="LibraryPathText" Text="Not set — games stay in their original location"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                               FontFamily="{DynamicResource PrimaryFont}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <Button Name="BrowseLibraryBtn" Grid.Column="1" Content="Browse…" Theme="{StaticResource PrefSecondaryBtn}" Margin="8,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,24,0,16"/>

                            <TextBlock Text="IMPORT BEHAVIOUR" Theme="{StaticResource PrefLabel}" Margin="0,0,0,4"/>
                            <TextBlock Text="Choose what happens when you add games to your library." FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <RadioButton Name="LibraryKeepInPlace" GroupName="LibImport" IsChecked="True" Cursor="Hand" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock Text="Keep games in their original location" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Emutastic tracks where your files are — nothing is copied or moved." FontSize="11"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Name="LibraryCopyFiles" GroupName="LibImport" Cursor="Hand" Margin="0,10,0,16">
                                <StackPanel>
                                    <TextBlock Text="Copy games to the library folder" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="A copy of each ROM is placed in your library folder. Requires a folder set above." FontSize="11"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </RadioButton>
                            <CheckBox Name="LibraryOrganizeByConsole" Content="Organize copied games into sub-folders by console"
                                      Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="22,0,0,0"/>

                            <Button Name="LibrarySaveBtn" Content="Save" Theme="{StaticResource PrefActionBtn}" HorizontalAlignment="Left" Margin="0,24,0,0"/>
                            <TextBlock Name="LibraryStatusText" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <Grid Name="PanelTheme" IsVisible="False">
                    <ScrollViewer Margin="32,24,32,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="THEME" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <TextBlock Text="Color theme" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Choose a color theme for the entire app. Changes take effect immediately."
                                       FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,8" TextWrapping="Wrap"/>
                            <!-- Upstream's "Customize…" opened ThemeEditorWindow; on Linux theme
                                 customization lives in the panels themselves (swatches + .emutheme
                                 import here, the Toast Appearance editor on the Achievements panel),
                                 so the dead coming-soon button is dropped rather than shipped. -->
                            <ComboBox Name="ThemeCombo" Width="220" Theme="{StaticResource DarkComboBox}"/>

                            <TextBlock Text="INSTALLED THEMES" Theme="{StaticResource PrefLabel}" Margin="0,22,0,4"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,12"/>
                            <WrapPanel Name="InstalledThemesPanel" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Name="ImportThemeBtn" Content="Import Theme…" Theme="{StaticResource PrefSecondaryBtn}"
                                        Padding="10,4" FontSize="12"/>
                            </StackPanel>

                            <TextBlock Text="BACKGROUND IMAGE" Theme="{StaticResource PrefLabel}" Margin="0,24,0,4"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,12"/>

                            <TextBlock Text="Grid background image" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Display a background image behind your game library grid."
                                       FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,8" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Name="BgImagePickBtn" Content="Choose Image…" Theme="{StaticResource PrefSecondaryBtn}" Padding="10,4" FontSize="12"/>
                                <Button Name="BgImageClearBtn" Content="Clear" Theme="{StaticResource PrefSecondaryBtn}" Padding="10,4" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Name="BgImagePathLabel" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"
                                       TextTrimming="CharacterEllipsis" MaxWidth="400" HorizontalAlignment="Left"/>

                            <TextBlock Text="Opacity" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,14,0,4"/>
                            <Grid ColumnDefinitions="*,40">
                                <Slider Name="BgOpacitySlider" Grid.Column="0" Minimum="0" Maximum="100"
                                        TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                <TextBlock Name="BgOpacityValueLabel" Grid.Column="1" Text="100%" FontSize="12"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <TextBlock Text="Image fit" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,14,0,4"/>
                            <ComboBox Name="BgStretchCombo" Width="180" Theme="{StaticResource DarkComboBox}" HorizontalAlignment="Left"/>

                            <!-- ══ PAUSE EFFECT ══ -->
                            <TextBlock Text="PAUSE EFFECT" Theme="{StaticResource PrefLabel}" Margin="0,28,0,4"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Animated overlay while paused" FontSize="13"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="A subtle animation drawn on top of the paused game frame. Set to None to disable."
                                           FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,8" TextWrapping="Wrap"/>
                                <ComboBox Name="PauseEffectCombo" Width="220" Theme="{StaticResource DarkComboBox}" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Intensity" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Density and speed multiplier (e.g. snowflake count, particle count)." FontSize="11"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,8" TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="*,44" Margin="0,4,0,0">
                                    <Slider Name="PauseEffectIntensitySlider" Grid.Column="0" Minimum="50" Maximum="200"
                                            TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Name="PauseEffectIntensityValueLabel" Grid.Column="1" Text="100%" FontSize="12"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>

                            <Border Background="#FF101015" BorderBrush="{DynamicResource BorderNormalBrush}" BorderThickness="1"
                                    CornerRadius="4" Height="120" Margin="0,0,0,8" ClipToBounds="True">
                                <pe:PauseEffectHost Name="PauseEffectPreview"/>
                            </Border>
                            <TextBlock Text="Preview" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,16"/>

                            <!-- ══ LAYOUT ══ -->
                            <TextBlock Text="LAYOUT" Theme="{StaticResource PrefLabel}" Margin="0,28,0,4"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Grid edge padding" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Space between the grid and the window edge." FontSize="11"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,8" TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="*,40">
                                    <Slider Name="PaddingSlider" Grid.Column="0" Minimum="8" Maximum="64"
                                            TickFrequency="2" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Name="PaddingValueLabel" Grid.Column="1" FontSize="12"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Card size" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Width of each game card. Height adjusts automatically to match the console's box art ratio."
                                           FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,8" TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="*,40">
                                    <Slider Name="CardSizeSlider" Grid.Column="0" Minimum="148" Maximum="280"
                                            TickFrequency="8" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Name="CardSizeValueLabel" Grid.Column="1" FontSize="12"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,4">
                                <TextBlock Text="Card spacing" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Gap between individual game cards." FontSize="11"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,8" TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="*,40">
                                    <Slider Name="SpacingSlider" Grid.Column="0" Minimum="4" Maximum="96"
                                            TickFrequency="4" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock Name="SpacingValueLabel" Grid.Column="1" FontSize="12"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>

                            <!-- ══ WINDOW STYLE ══ -->
                            <TextBlock Text="WINDOW STYLE" Theme="{StaticResource PrefLabel}" Margin="0,28,0,4"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <CheckBox Name="NativeChromeCheck" Content="Use native window controls"
                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,0,2"/>
                            <TextBlock Text="Use the system title bar with real minimize / maximize / close buttons instead of the custom frameless window. Restart to apply."
                                       FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,16" TextWrapping="Wrap"/>

                            <StackPanel Margin="0,0,0,4">
                                <TextBlock Text="Title-bar buttons" FontSize="13" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Look of the minimize / maximize / close buttons across the app." FontSize="11"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,8" TextWrapping="Wrap"/>
                                <ComboBox Name="WindowStyleCombo" Width="220" Theme="{StaticResource DarkComboBox}" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="macOS" Tag="macOS"/>
                                    <ComboBoxItem Content="Windows 11" Tag="Windows11"/>
                                    <ComboBoxItem Content="Linux (native)" Tag="Linux"/>
                                </ComboBox>
                            </StackPanel>

                            <TextBlock Name="ThemeStatusText" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <Grid Name="PanelSnaps" IsVisible="False">
                    <ScrollViewer Margin="32,24,32,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="VIDEO SNAPS" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>
                            <TextBlock Text="When a game card is opened, Emutastic can play a video preview instead of a static screenshot. Configure the ScreenScraper provider below."
                                       FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,24"/>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ScreenScraper" FontSize="15" FontWeight="SemiBold"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Free accounts at screenscraper.fr — no developer registration required."
                                               FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                                <ToggleSwitch Name="SSEnabledToggle" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Username" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Name="SSUsernameBox" Margin="0,0,0,14" Background="{DynamicResource BgTertiaryBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                     FontFamily="{DynamicResource PrimaryFont}"/>

                            <TextBlock Text="Password" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Name="SSPasswordBox" PasswordChar="●" Margin="0,0,0,20" Background="{DynamicResource BgTertiaryBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                     FontFamily="{DynamicResource PrimaryFont}"/>

                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                                <Button Name="SSTestBtn" Content="Login" Theme="{StaticResource PrefActionBtn}"/>
                                <TextBlock Name="SSStatusLabel" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,20,0,20"/>

                            <TextBlock Text="2D ARTWORK SOURCE" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Prefer ScreenScraper 2D art" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"
                                               Text="Use higher-quality ScreenScraper box art instead of libretro thumbnails. Free accounts have low API limits — best on paid tiers."/>
                                </StackPanel>
                                <ToggleSwitch Name="SSPrefer2DToggle" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center" IsEnabled="False"/>
                            </Grid>

                            <TextBlock Text="EmuMovies support is coming once their v3 API ships."
                                       FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,20,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <Grid Name="PanelAchievements" IsVisible="False">
                    <ScrollViewer Margin="32,24,32,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="RETROACHIEVEMENTS" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <TextBlock Text="Earn achievements while you play! Connect your RetroAchievements.org account to track progress across supported games."
                                       FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,24"/>

                            <!-- Signing in (entering credentials below) is all that's needed —
                                 there is no separate enable toggle. -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="RetroAchievements" FontSize="15" FontWeight="SemiBold"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Create a free account at retroachievements.org, then sign in below — that's all it takes. Your password is used to obtain a login token; it is not stored."
                                           FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Username" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Name="RAUsernameBox" Margin="0,0,0,14" Background="{DynamicResource BgTertiaryBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                     FontFamily="{DynamicResource PrimaryFont}"/>

                            <TextBlock Text="Password" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Name="RAPasswordBox" PasswordChar="●" Margin="0,0,0,14" Background="{DynamicResource BgTertiaryBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                     FontFamily="{DynamicResource PrimaryFont}"/>

                            <!-- Web API Key. Masked because anyone with this key can read the
                                 user's RA account data (achievements, progress, friends list). -->
                            <TextBlock Text="Web API Key" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Name="RAApiKeyBox" PasswordChar="●" Margin="0,0,0,4" Background="{DynamicResource BgTertiaryBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                     FontFamily="{DynamicResource PrimaryFont}"/>
                            <TextBlock Text="Separate from your password. Grab it from retroachievements.org → Settings → Web API Key. Used for in-app time-to-beat / achievement stats."
                                       FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,14"/>

                            <TextBlock Name="RATokenStatus" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,20"/>

                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,24">
                                <Button Name="RATestBtn" Content="Login" Theme="{StaticResource PrefActionBtn}"/>
                                <TextBlock Name="RAStatusLabel" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,20"/>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="Hardcore Mode" FontSize="14" FontWeight="SemiBold"/>
                                        <Run Text=" (server approval pending)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </TextBlock>
                                    <TextBlock Text="Disables save state loading and cheat codes during gameplay. Required for hardcore achievement unlocks."
                                               FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0">
                                        <Run Text="Note:"/>
                                        <Run Text=" RetroAchievements requires an emulator to be public for 6 months before approving it for hardcore. Earliest we can apply is October 2026 — until then unlocks earned here count as softcore on RA's servers."
                                             FontStyle="Italic"/>
                                    </TextBlock>
                                </StackPanel>
                                <ToggleSwitch Name="RAHardcoreToggle" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,16,0,16"/>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Sync follows from RetroAchievements on launch" FontSize="14" FontWeight="SemiBold"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="When enabled, Emutastic pulls your retroachievements.org follow list at startup and adds anyone new to your friends list. Existing friends are never removed; their notification preferences are preserved. New entries are muted by default — toggle the bell on each friend card to enable toasts. Takes effect on next launch."
                                               FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                                <ToggleSwitch Name="RASyncFollowsToggle" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,20"/>

                            <!-- ── Toast appearance ─────────────────────────────
                                 Interactive controls are built procedurally into
                                 TsAppearanceHost by BuildToastAppearanceUI() in
                                 code-behind (upstream's ThemeEditor pattern). -->
                            <TextBlock Text="TOAST APPEARANCE" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>
                            <TextBlock Text="Customize how the in-game achievement unlock toast looks — shape, background, border, drop shadow, text colors, fonts and sizes, where it appears, and how long it stays. Changes apply to the next unlock."
                                       FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,16"/>

                            <ContentControl Name="TsPreviewHost" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" Spacing="8">
                                <Button Name="TsPreviewBtn" Content="Preview animation" Theme="{StaticResource PrefActionBtn}"/>
                                <Button Name="TsResetBtn" Content="Reset to defaults" Theme="{StaticResource PrefActionBtn}"/>
                            </StackPanel>

                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="12,8,6,8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
                                    <StackPanel Name="TsAppearanceHost" Margin="0,0,6,0"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <Grid Name="PanelMedia" IsVisible="False">
                    <ScrollViewer Margin="32,24,32,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="MEDIA FOLDERS" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Margin="0,0,0,24"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="Choose where screenshots and recordings are saved. Per-console / per-game subfolders are still created inside your chosen directory."/>

                            <!-- Screenshots folder -->
                            <TextBlock Text="Screenshots" FontSize="14" FontWeight="SemiBold" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Name="ScreenshotsDefaultText" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <Border Grid.Column="0" Background="{DynamicResource BgTertiaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10,8">
                                    <TextBlock Name="ScreenshotsFolderText" Text="Default" Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12" FontFamily="{DynamicResource PrimaryFont}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <Button Name="BrowseScreenshotsBtn" Grid.Column="1" Content="Browse…" Theme="{StaticResource PrefSecondaryBtn}" Margin="8,0,0,0"/>
                                <Button Name="ClearScreenshotsBtn" Grid.Column="2" Content="Clear" Theme="{StaticResource PrefSecondaryBtn}" Margin="4,0,0,0"/>
                            </Grid>

                            <TextBlock Text="Screenshot hotkey" FontSize="13" FontWeight="SemiBold" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,18,0,4"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Border Grid.Column="0" Background="{DynamicResource BgTertiaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10,8">
                                    <TextBox Name="ScreenshotHotkeyBox" Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                             Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                             Text="F12 (default)" ToolTip.Tip="Click here and press a key to set the screenshot hotkey."/>
                                </Border>
                                <Button Name="ResetHotkeyBtn" Grid.Column="1" Content="Reset" Theme="{StaticResource PrefSecondaryBtn}" Margin="8,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,24,0,16"/>

                            <!-- Recordings folder -->
                            <TextBlock Text="Recordings" FontSize="14" FontWeight="SemiBold" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Name="RecordingsDefaultText" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <Border Grid.Column="0" Background="{DynamicResource BgTertiaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10,8">
                                    <TextBlock Name="RecordingsFolderText" Text="Default" Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12" FontFamily="{DynamicResource PrimaryFont}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <Button Name="BrowseRecordingsBtn" Grid.Column="1" Content="Browse…" Theme="{StaticResource PrefSecondaryBtn}" Margin="8,0,0,0"/>
                                <Button Name="ClearRecordingsBtn" Grid.Column="2" Content="Clear" Theme="{StaticResource PrefSecondaryBtn}" Margin="4,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,24,0,16"/>

                            <!-- Recording quality (capture lands with the emulator/ffmpeg splinter) -->
                            <TextBlock Text="RECORDING QUALITY" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>
                            <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" >
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Quality" VerticalAlignment="Center" FontSize="13" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <ComboBox Name="RecQualityCombo" Grid.Row="0" Grid.Column="1" Width="200" HorizontalAlignment="Left" Theme="{StaticResource DarkComboBox}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Output scale" VerticalAlignment="Center" FontSize="13" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <ComboBox Name="RecScaleCombo" Grid.Row="1" Grid.Column="1" Width="200" HorizontalAlignment="Left" Theme="{StaticResource DarkComboBox}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Encoder" VerticalAlignment="Center" FontSize="13" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <ComboBox Name="RecEncoderCombo" Grid.Row="2" Grid.Column="1" Width="200" HorizontalAlignment="Left" Theme="{StaticResource DarkComboBox}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Audio bitrate" VerticalAlignment="Center" FontSize="13" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <ComboBox Name="RecAudioBitrateCombo" Grid.Row="3" Grid.Column="1" Width="200" HorizontalAlignment="Left" Theme="{StaticResource DarkComboBox}" Margin="0,0,0,8"/>
                                <CheckBox Name="RecHighChromaCheck" Grid.Row="4" Grid.Column="1" Content="High chroma (4:4:4) — sharper text, larger files"
                                          Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <Grid Name="PanelBackups" IsVisible="False">
                    <ScrollViewer Margin="32,24,32,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="LOCAL BACKUP" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="Set a folder to back up your battery saves, save states, and library database. Only save data is backed up — artwork and snaps are excluded to keep backups small."/>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <Border Grid.Column="0" Background="{DynamicResource BgTertiaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10,8">
                                    <TextBlock Name="BackupFolderPathText" Text="Not set" Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12" FontFamily="{DynamicResource PrimaryFont}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <Button Name="BrowseBackupFolderBtn" Grid.Column="1" Content="Browse…" Theme="{StaticResource PrefSecondaryBtn}" Margin="8,0,0,0"/>
                                <Button Name="ClearBackupFolderBtn" Grid.Column="2" Content="Clear" Theme="{StaticResource PrefSecondaryBtn}" Margin="4,0,0,0"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                                <Button Name="BackupNowBtn" Content="Back Up Now" Theme="{StaticResource PrefActionBtn}"/>
                                <Button Name="RestoreBackupBtn" Content="Restore from Backup…" Theme="{StaticResource PrefSecondaryBtn}"/>
                                <TextBlock Name="BackupFolderStatusText" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                           FontFamily="{DynamicResource PrimaryFont}" VerticalAlignment="Center"/>
                            </StackPanel>

                        
                            <!-- ── Cloud Sync (GitHub) — A9 port of upstream's Backups section ── -->
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,24,0,16"/>
                            <TextBlock Text="CLOUD SYNC (GITHUB)" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="Sync battery saves and your database file across PCs using a private GitHub repository. Sign in with your GitHub account — a private repo is created automatically."
                                       TextWrapping="Wrap" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                            <!-- Sign in / status -->
                            <Border Background="{DynamicResource BgTertiaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Name="CloudSyncStatusText" Text="Not signed in" FontFamily="{DynamicResource PrimaryFont}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                    <Button Name="CloudSyncSignInBtn" Content="Sign in with GitHub" Grid.Column="1"
                                            Theme="{StaticResource PrefActionBtn}" Padding="14,8"/>
                                </Grid>
                            </Border>

                            <!-- Device flow code display (hidden until auth starts) -->
                            <Border Name="DeviceFlowPanel" IsVisible="False" Background="{DynamicResource BgTertiaryBrush}"
                                    BorderBrush="{DynamicResource BorderNormalBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="14,14" Margin="0,0,0,12">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Enter this code on GitHub:" FontFamily="{DynamicResource PrimaryFont}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Center"/>
                                    <TextBlock Name="DeviceFlowCodeText" FontSize="28" FontWeight="Bold" FontFamily="monospace"
                                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,8"/>
                                    <TextBlock Text="Waiting for authorization…" FontFamily="{DynamicResource PrimaryFont}"
                                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Sync settings (visible only when signed in) -->
                            <StackPanel Name="CloudSyncSettingsPanel" IsVisible="False">
                                <TextBlock Text="SYNC TIMING" Theme="{StaticResource PrefLabel}" Margin="0,4,0,8"/>
                                <RadioButton Name="SyncOnClose" Content="On game close (recommended)" GroupName="SyncTiming"
                                             FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"
                                             FontSize="13" IsChecked="True" Margin="0,0,0,6"/>
                                <RadioButton Name="SyncPeriodic" Content="Every 15 minutes during play" GroupName="SyncTiming"
                                             FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"
                                             FontSize="13" Margin="0,0,0,6"/>
                                <RadioButton Name="SyncManual" Content="Manual only" GroupName="SyncTiming"
                                             FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"
                                             FontSize="13" Margin="0,0,0,12"/>

                                <TextBlock Text="ENCRYPTION" Theme="{StaticResource PrefLabel}" Margin="0,4,0,8"/>
                                <CheckBox Name="SyncEncryptionEnabled" Content="Encrypt saves before upload"
                                          FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"
                                          FontSize="13" Margin="0,0,0,8"/>
                                <StackPanel Name="PassphrasePanel" IsVisible="False" Orientation="Horizontal" Margin="22,0,0,4">
                                    <TextBox Name="SyncPassphraseBox" PasswordChar="●" Width="200" FontSize="13" Padding="8,6"
                                             Background="{DynamicResource BgTertiaryBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource BorderNormalBrush}"/>
                                    <Button Name="SyncPassphraseSaveBtn" Content="Save" Theme="{StaticResource PrefSecondaryBtn}"
                                            Margin="8,0,0,0" Padding="14,6"/>
                                </StackPanel>
                                <TextBlock Name="PassphraseHint" Text="Same passphrase required on all PCs" IsVisible="False"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11" Margin="22,0,0,12"/>

                                <TextBlock Text="REPOSITORY" Theme="{StaticResource PrefLabel}" Margin="0,16,0,8"/>
                                <CheckBox Name="SyncPerPcRepo"
                                          Content="Make this PC unique — don't share saves or library with other PCs"
                                          FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"
                                          FontSize="13" Margin="0,0,0,4"/>
                                <TextBlock Name="SyncRepoExplainText"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11" Margin="22,0,0,2" TextWrapping="Wrap"
                                           Text="Off: this PC shares one cloud repository with your other PCs — saves and your game library follow you between machines."/>
                                <TextBlock Name="SyncRepoNameText"
                                           FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11" Margin="22,2,0,0"/>

                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Name="SyncNowBtn" Content="Sync Now" Theme="{StaticResource PrefActionBtn}" Padding="14,8"/>
                                    <TextBlock Name="SyncStatusText" FontFamily="{DynamicResource PrimaryFont}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <!-- ── PANEL: EmuTV ─────────────────────────────────────── -->
                <Grid Name="PanelEmuTv" IsVisible="False">
                    <ScrollViewer Margin="32,24,32,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                            <TextBlock Text="EMUTV" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <!-- Hi-res art -->
                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hi-Res Box Art (SteamGridDB)" FontSize="15" FontWeight="SemiBold"
                                               FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Upgrade missing or low-res box art and logos for the couch view using SteamGridDB. Get a free token at steamgriddb.com (Profile - Preferences - API), then paste it here. Your token stays on this PC."
                                               FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                                <ToggleSwitch Name="SgdbEnabledToggle" Grid.Column="1" OnContent="" OffContent="" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="API Token" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Name="SgdbTokenBox" Margin="0,0,0,10" Background="{DynamicResource BgTertiaryBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                     FontFamily="{DynamicResource PrimaryFont}"/>
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,26">
                                <Button Name="SgdbTestBtn" Content="Verify" Theme="{StaticResource PrefActionBtn}"/>
                                <TextBlock Name="SgdbStatusLabel" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- EmuTV nav rebinds -->
                            <TextBlock Text="EmuTV Controls" FontSize="15" FontWeight="SemiBold"
                                       FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Change the buttons used inside EmuTV. Navigation (D-pad / stick), A (play) and B (back) are fixed."
                                       FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,12"/>
                            <Grid ColumnDefinitions="200,170" Margin="0,0,0,10">
                                <TextBlock Grid.Column="0" Text="Theme browser" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <ComboBox Name="HkThemeBrowser" Grid.Column="1" Width="170" Theme="{StaticResource DarkComboBox}"/>
                            </Grid>
                            <Grid ColumnDefinitions="200,170" Margin="0,0,0,18">
                                <TextBlock Grid.Column="0" Text="Save states" FontFamily="{DynamicResource PrimaryFont}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <ComboBox Name="HkSaveStates" Grid.Column="1" Width="170" Theme="{StaticResource DarkComboBox}"/>
                            </Grid>

                            <!-- In-game combo reference -->
                            <TextBlock Text="Controller combos" FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,6"/>
                            <Border Background="{DynamicResource BgTertiaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14,12">
                                <StackPanel>
                                    <TextBlock FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="Open EmuTV / quit game"/>
                                        <Run Text="    L3 + R3 + L2 + R2 (held ~1.5s)"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0">
                                        <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="Save state"/>
                                        <Run Text="    Hold L3, then R2"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0">
                                        <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="Load latest state"/>
                                        <Run Text="    Hold R3, then L2"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0">
                                        <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="Swap disc"/>
                                        <Run Text="    L3 + Start (multi-disc games)"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"
                                               Text="The save/load/disc combos are rebindable per system under Controls."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <Grid Name="PanelAbout" IsVisible="False">
                    <ScrollViewer Margin="32,24,32,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                            <TextBlock Text="ABOUT" Theme="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <TextBlock Text="Emutastic" FontSize="24" FontWeight="Bold"
                                       FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="An OpenEmu-style retro game library, ported to Linux."
                                       FontSize="12" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,24"/>

                            <TextBlock Text="Installed Version" FontSize="11" FontWeight="SemiBold"
                                       FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Name="AboutInstalledVersionText" Text="v0.0.0" FontSize="14"
                                       FontFamily="monospace" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                            <TextBlock Text="Latest Release" FontSize="11" FontWeight="SemiBold"
                                       FontFamily="{DynamicResource PrimaryFont}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Name="AboutLatestVersionText" Text="Checking…" FontSize="14"
                                       FontFamily="monospace" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Name="AboutUpdateStatusText" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <Button Name="AboutUpdateNowBtn" Content="Update Now" Theme="{StaticResource PrefActionBtn}" IsVisible="False"/>
                                <Button Name="AboutOpenLatestReleaseBtn" Content="Open Latest Release" Theme="{StaticResource PrefSecondaryBtn}" IsVisible="False"/>
                                <Button Name="AboutOpenRepoBtn" Content="View on GitHub" Theme="{StaticResource PrefSecondaryBtn}"/>
                                <Button Name="AboutRecheckBtn" Content="Check Again" Theme="{StaticResource PrefSecondaryBtn}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
                                <Button Name="AboutLicenseBtn" Content="License (GPL-3.0)" Theme="{StaticResource PrefSecondaryBtn}"/>
                                <Button Name="AboutCoresBtn" Content="Cores &amp; Licenses" Theme="{StaticResource PrefSecondaryBtn}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
        </Border>
    </Border>
</Window>
