<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pe="using:Emutastic.Views.PauseEffects"
        xmlns:platform="using:Emutastic.Platform"
        x:Class="Emutastic.Views.EmulatorWindow"
        Icon="/Assets/banners and icons/emutastic-logo.png"
        Width="768" Height="720" MinWidth="480" MinHeight="360"
        Title="Emutastic — Emulator"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowDecorations="None">

    <Window.Resources>
        <!-- Circular translucent icon button for the in-game HUD pill. -->
        <ControlTheme x:Key="OverlayPillBtn" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="b" Background="{TemplateBinding Background}" CornerRadius="24">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#b"><Setter Property="Background" Value="#33FFFFFF"/></Style>
        </ControlTheme>
    </Window.Resources>

    <!-- Themed shell to match the rest of the app (rounded chrome + dark title bar). Software frames
         blit into the Screen Image; the HW (GL/Vulkan) path swaps it for a NativeControlHost child. -->
    <!-- NOTE: no DropShadowEffect here. An Avalonia Effect renders its whole subtree to an offscreen
         target and re-applies (here a 30px blur) whenever the subtree invalidates — and the live game
         Image invalidates 60x/sec, so the blur was being recomputed every frame over the entire window,
         causing gameplay stutter. Upstream (WPF) uses native chrome and the OS draws the window shadow;
         on Linux the WM/compositor draws it too, so we just drop the in-app shadow. -->
    <Border x:Name="OuterBorder" Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="10">
        <Border CornerRadius="10" ClipToBounds="True">
            <Grid RowDefinitions="38,*,Auto">
                <!-- ══ TITLE BAR ══ -->
                <Grid Name="CustomTitleBar" Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}" ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0" Spacing="7">
                        <Image Width="18" Height="18" RenderOptions.BitmapInterpolationMode="HighQuality"
                               Source="avares://Emutastic/Assets/banners and icons/emutastic-logo.png"/>
                        <TextBlock Name="TitleText" Text="Emutastic" FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="{DynamicResource WinBtnStripVAlign}"
                                Margin="{DynamicResource WinBtnStripMargin}"
                                Spacing="{DynamicResource WinBtnStripSpacing}">
                        <Button Name="MinimizeButton" Padding="0" Theme="{DynamicResource ActiveMinButton}" ToolTip.Tip="Minimize"/>
                        <Button Name="MaximizeButton" Padding="0" Theme="{DynamicResource ActiveMaxButton}" ToolTip.Tip="Maximize"/>
                        <Button Name="CloseButton" Padding="0" Theme="{DynamicResource ActiveCloseButton}" ToolTip.Tip="Close"/>
                    </StackPanel>
                </Grid>

                <!-- ══ SCREEN + in-game overlay ══ -->
                <!-- GameViewport: the video region. When the Vulkan overlay is active it floats a
                     borderless top-level window exactly over this Panel (screen rect via PointToScreen);
                     otherwise the WriteableBitmap Image renders here (automatic fallback). -->
                <Panel Grid.Row="1" Name="GameViewport" Background="Black">
                    <Image Name="Screen" Stretch="Uniform"/>

                    <!-- Pause-effect animation (over the frozen frame; never eats input). -->
                    <pe:PauseEffectHost Name="PauseEffectOverlay" IsVisible="False" IsHitTestVisible="False"/>

                    <!-- Hover HUD pill (bottom-center). O2 stacks the cog/save menus above this. -->
                    <StackPanel Name="OverlayHud" IsVisible="False" Opacity="0"
                                VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,22">
                        <Border Background="#EE0F0F11" BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="26" Padding="8,4">
                            <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                <Button Name="OverlayPowerBtn" Theme="{StaticResource OverlayPillBtn}" ToolTip.Tip="Close Game">
                                    <Image Source="avares://Emutastic/Assets/buttons/powerbutton.png" Width="40" Height="40"
                                           RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                </Button>
                                <Button Name="OverlayPauseBtn" Theme="{StaticResource OverlayPillBtn}" ToolTip.Tip="Pause / Resume">
                                    <TextBlock Name="OverlayPauseGlyph" Text="⏸" FontSize="20" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button Name="OverlayResetBtn" Theme="{StaticResource OverlayPillBtn}" ToolTip.Tip="Reset Game">
                                    <TextBlock Text="⟳" FontSize="22" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Panel>

                <!-- ══ BOTTOM STATUS BAR ══ real fps / target / core.Run avg (matches upstream StatusText) -->
                <Border Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}" Height="22">
                    <TextBlock Name="StatusText" Text="Starting…"
                               FontFamily="{DynamicResource PrimaryFont}" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="12,0"/>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
