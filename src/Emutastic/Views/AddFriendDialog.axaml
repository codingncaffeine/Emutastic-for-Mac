<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Emutastic.Views.AddFriendDialog"
        Title="Add Friend"
        WindowDecorations="None" TransparencyLevelHint="Transparent" Background="Transparent"
        CanResize="False" ShowInTaskbar="False"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
    <Border Background="{DynamicResource BgSecondaryBrush}" BorderBrush="{DynamicResource BorderNormalBrush}"
            BorderThickness="1" CornerRadius="10">
        <StackPanel Margin="24">
            <TextBlock Text="Add Friend" FontFamily="{DynamicResource PrimaryFont}" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
            <TextBlock Text="Enter a RetroAchievements username:" FontFamily="{DynamicResource PrimaryFont}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Name="UsernameInput" Grid.Column="0" FontFamily="{DynamicResource PrimaryFont}" FontSize="13"
                         Padding="8,6" Background="{DynamicResource BgTertiaryBrush}"
                         BorderBrush="{DynamicResource BorderSubtleBrush}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Button Name="LookupBtn" Grid.Column="1" Content="Lookup" Padding="14,6" Margin="8,0,0,0"
                        Theme="{StaticResource PrefActionBtn}"/>
            </Grid>
            <!-- Preview card (populated after a successful lookup) -->
            <Border Name="PreviewCard" Background="{DynamicResource BgTertiaryBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8"
                    Padding="12" Margin="0,14,0,0" IsVisible="False">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                            Background="{DynamicResource BgSecondaryBrush}" ClipToBounds="True">
                        <Image Name="PreviewAvatar" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Name="PreviewName" FontFamily="{DynamicResource PrimaryFont}" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Name="PreviewPoints" FontFamily="{DynamicResource PrimaryFont}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                        <TextBlock Name="PreviewMotto" FontFamily="{DynamicResource PrimaryFont}" FontSize="11"
                                   FontStyle="Italic" Foreground="{DynamicResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            <TextBlock Name="ErrorText" FontFamily="{DynamicResource PrimaryFont}" FontSize="11"
                       Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap" Margin="0,8,0,0" IsVisible="False"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0" Spacing="8">
                <Button Name="CancelBtn" Content="Cancel" Padding="16,8"/>
                <Button Name="AddBtn" Content="Add Friend" Padding="16,8" IsEnabled="False"
                        Theme="{StaticResource PrefActionBtn}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
