<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:Emutastic.Converters"
        xmlns:vm="using:Emutastic.ViewModels"
        xmlns:models="using:Emutastic.Models"
        xmlns:ctl="using:Emutastic.Controls"
        x:Class="Emutastic.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        x:CompileBindings="False"
        Width="1100" Height="720" MinWidth="800" MinHeight="500"
        Title="Emutastic"
        Icon="/Assets/banners and icons/emutastic-logo.png"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowDecorations="None">

    <!-- M4c shell: 1:1 main-window clone (title bar + sidebar + flat box-art grid + status banner).
         Rounded window shell (matches upstream OuterBorder): bg+border+radius, then an inner
         ClipToBounds border so child content respects the rounded corners. -->
    <Border x:Name="OuterBorder" Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" OffsetX="0" OffsetY="0" Opacity="0.6" Color="{DynamicResource ShadowColor}"/>
        </Border.Effect>
        <Border x:Name="InnerClip" CornerRadius="10" ClipToBounds="True">
    <Grid Name="RootGrid" RowDefinitions="38,*,Auto">

        <!-- ══ TITLE BAR ══ -->
        <Grid Name="CustomTitleBar" Grid.Row="0" ColumnDefinitions="220,*">
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Image Width="20" Height="20" Margin="0,0,7,0"
                           RenderOptions.BitmapInterpolationMode="HighQuality"
                           Source="avares://Emutastic/Assets/banners and icons/emutastic-logo.png"/>
                    <TextBlock Text="Emutastic" FontFamily="{DynamicResource PrimaryFont}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Grid Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}" ColumnDefinitions="*,Auto">
                <!-- drag zone -->
                <Border Name="DragZone" Grid.Column="0" Background="Transparent"/>
                <!-- window buttons — style (mac / Win11 / Linux) swaps via Active*Button; the strip
                     layout (margin/spacing/v-align) also swaps so Win11 sits flush in the corner -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="{DynamicResource WinBtnStripVAlign}"
                            Margin="{DynamicResource WinBtnStripMargin}"
                            Spacing="{DynamicResource WinBtnStripSpacing}">
                    <Button Name="MinimizeButton" Padding="0" Theme="{DynamicResource ActiveMinButton}" ToolTip.Tip="Minimize"/>
                    <Button Name="MaximizeButton" Padding="0" Theme="{DynamicResource ActiveMaxButton}" ToolTip.Tip="Maximize"/>
                    <Button Name="CloseButton" Padding="0" Theme="{DynamicResource ActiveCloseButton}" ToolTip.Tip="Close"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ══ BODY ══ -->
        <Grid Grid.Row="1" ColumnDefinitions="220,*">

            <!-- ── SIDEBAR ── -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondaryBrush}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="SidebarPanel" Margin="0,6,0,12">
                        <TextBlock Text="LIBRARY" Theme="{DynamicResource LabelMuted}" Margin="16,10,0,4"/>
                        <Button Theme="{DynamicResource SidebarItemStyle}" Content="All Games" Tag="All Games"
                                Command="{Binding NavigateToAllGamesCommand}"/>
                        <Button Theme="{DynamicResource SidebarItemStyle}" Content="◷  Recently Played" Tag="Recent"
                                Command="{Binding NavigateToRecentCommand}"/>
                        <Button Theme="{DynamicResource SidebarItemStyle}" Content="♡  Favorites" Tag="Favorites"
                                Command="{Binding NavigateToFavoritesCommand}"/>
                        <Button Theme="{DynamicResource SidebarItemStyle}" Content="Recently Added" Tag="RecentlyAdded"
                                Command="{Binding NavigateToRecentlyAddedCommand}"/>

                        <Rectangle Height="1" Fill="{DynamicResource BorderSubtleBrush}" Margin="12,8"/>
                        <TextBlock Text="CONSOLES" Theme="{DynamicResource LabelMuted}" Margin="16,4,0,4"/>

                        <!-- Arcade (top of consoles) -->
                        <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="Arcade">
                            <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="🕹" FontSize="16" Width="20" TextAlignment="Center" VerticalAlignment="Center"/><TextBlock Text="Arcade" VerticalAlignment="Center"/></StackPanel></Button>

                        <Expander Theme="{StaticResource SidebarExpander}" Header="ATARI" Margin="6,4,0,0" IsExpanded="True">
                            <StackPanel>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="Atari2600"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='Atari2600'}"/><TextBlock Text="Atari 2600" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="Atari7800"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='Atari7800'}"/><TextBlock Text="Atari 7800" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="Jaguar"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='Jaguar'}"/><TextBlock Text="Atari Jaguar" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>
                        </Expander>

                        <Expander Theme="{StaticResource SidebarExpander}" Header="NINTENDO" Margin="6,2,0,0" IsExpanded="True">
                            <StackPanel>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="NES"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='NES'}"/><TextBlock Text="Nintendo (NES)" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="FDS"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='FDS'}"/><TextBlock Text="Famicom Disk System" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="SNES"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='SNES'}"/><TextBlock Text="Super Nintendo" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="N64"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='N64'}"/><TextBlock Text="Nintendo 64" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="GameCube"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='GameCube'}"/><TextBlock Text="GameCube" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="GB"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='GB'}"/><TextBlock Text="Game Boy" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="GBC"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='GBC'}"/><TextBlock Text="Game Boy Color" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="GBA"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='GBA'}"/><TextBlock Text="Game Boy Advance" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="3DS"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='3DS'}"/><TextBlock Text="Nintendo 3DS" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="NDS"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='NDS'}"/><TextBlock Text="Nintendo DS" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="VirtualBoy"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='VirtualBoy'}"/><TextBlock Text="Virtual Boy" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>
                        </Expander>

                        <Expander Theme="{StaticResource SidebarExpander}" Header="SEGA" Margin="6,2,0,0" IsExpanded="True">
                            <StackPanel>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="SMS"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='SMS'}"/><TextBlock Text="Sega Master System" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="Genesis"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='Genesis'}"/><TextBlock Text="Sega Genesis" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="SegaCD"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='SegaCD'}"/><TextBlock Text="Sega CD" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="Sega32X"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='Sega32X'}"/><TextBlock Text="Sega 32X" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="Saturn"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='Saturn'}"/><TextBlock Text="Sega Saturn" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="GameGear"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='GameGear'}"/><TextBlock Text="Sega Game Gear" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="SG1000"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='SG1000'}"/><TextBlock Text="SG-1000" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="Dreamcast"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='Dreamcast'}"/><TextBlock Text="Dreamcast" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>
                        </Expander>

                        <Expander Theme="{StaticResource SidebarExpander}" Header="SONY" Margin="6,2,0,0" IsExpanded="True">
                            <StackPanel>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="PS1"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='PS1'}"/><TextBlock Text="PlayStation" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="PS2"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='PS2'}"/><TextBlock Text="PlayStation 2" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="PSP"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='PSP'}"/><TextBlock Text="PSP" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>
                        </Expander>

                        <Expander Theme="{StaticResource SidebarExpander}" Header="NEC" Margin="6,2,0,0" IsExpanded="True">
                            <StackPanel>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="TG16"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='TG16'}"/><TextBlock Text="TurboGrafx-16" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="TGCD"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='TGCD'}"/><TextBlock Text="TurboGrafx-CD" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>
                        </Expander>

                        <Expander Theme="{StaticResource SidebarExpander}" Header="SNK" Margin="6,2,0,0" IsExpanded="True">
                            <StackPanel>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="NeoGeo"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='NeoGeo'}"/><TextBlock Text="Neo Geo" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="NeoCD"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='NeoCD'}"/><TextBlock Text="Neo Geo CD" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="NGP"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='NGP'}"/><TextBlock Text="NeoGeo Pocket" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>
                        </Expander>

                        <Expander Theme="{StaticResource SidebarExpander}" Header="OTHER" Margin="6,2,0,0" IsExpanded="True">
                            <StackPanel>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="3DO"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='3DO'}"/><TextBlock Text="3DO" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="CDi"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='CDi'}"/><TextBlock Text="Philips CD-i" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="ColecoVision"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='ColecoVision'}"/><TextBlock Text="ColecoVision" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Theme="{DynamicResource SidebarItemStyle}" Command="{Binding NavigateToConsoleCommand}" CommandParameter="Vectrex"><StackPanel Orientation="Horizontal" Spacing="8"><Image Width="20" Height="20" Source="{Binding Converter={StaticResource ConsoleTagToIcon}, Source='Vectrex'}"/><TextBlock Text="Vectrex" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>
                        </Expander>

                        <Rectangle Height="1" Fill="{DynamicResource BorderSubtleBrush}" Margin="12,10,12,0"/>
                        <Grid ColumnDefinitions="*,Auto" Margin="16,8,8,0">
                            <TextBlock Grid.Column="0" Text="COLLECTIONS" Theme="{DynamicResource LabelMuted}" Margin="0,0,0,4" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Name="NewCollectionButton" Content="＋" FontSize="13" Padding="6,0" Background="Transparent"
                                    BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand" ToolTip.Tip="New collection"/>
                        </Grid>
                        <StackPanel Name="UserCollectionsPanel"/>

                        <Rectangle Height="1" Fill="{DynamicResource BorderSubtleBrush}" Margin="12,10,12,0"/>
                        <TextBlock Text="OPTIONS" Theme="{DynamicResource LabelMuted}" Margin="16,8,0,4"/>
                        <Button Name="PreferencesButton" Theme="{DynamicResource SidebarItemStyle}" Content="⚙  Preferences"/>
                        <Button Name="ImportButton" Theme="{DynamicResource SidebarItemStyle}" Content="↓  Import ROMs"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── CONTENT ── -->
            <Grid Grid.Column="1" Background="{DynamicResource ContentBgBrush}" RowDefinitions="44,*">

                <!-- toolbar: [view toggles] | [tabs] | [search] (matches upstream layout) -->
                <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- LEFT: grid/list view toggles + 2D/3D box-art toggle. -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- grid/list view toggles (connected metallic segment). Wrapper Border
                                 carries the float drop shadow so the segments lift off the toolbar
                                 (upstream BlurRadius 6 / down 1 / 0.55). -->
                            <Border Background="Transparent" Margin="12,0,0,0" VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" OffsetX="0" OffsetY="1" Opacity="0.55" Color="Black"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton Name="ViewGrid" Theme="{StaticResource ViewGridToggle}" IsChecked="True" Tag="Grid" ToolTip.Tip="Grid view"/>
                                    <ToggleButton Name="ViewList" Theme="{StaticResource ViewListToggle}" Tag="List" ToolTip.Tip="List view"/>
                                </StackPanel>
                            </Border>

                            <!-- 2D / 3D box-art toggle — hidden until the current view has 3D box art
                                 (set visible by UpdateBoxArtToggleVisibility / BoxArt3DFetched). -->
                            <Border Name="BoxArtTogglePanel" Background="Transparent" Margin="6,0,0,0"
                                    VerticalAlignment="Center" IsVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" OffsetX="0" OffsetY="1" Opacity="0.55" Color="Black"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton Name="BoxArt2D" Theme="{StaticResource BoxArt2DToggle}" IsChecked="True" Tag="2D" ToolTip.Tip="2D Box Art"/>
                                    <ToggleButton Name="BoxArt3D" Theme="{StaticResource BoxArt3DToggle}" Tag="3D" ToolTip.Tip="3D Box Art"/>
                                </StackPanel>
                            </Border>

                            <!-- Per-console card spacing: fused H/V cap + slider. The cap toggles which
                                 axis the slider drives; each console remembers its own H and V spacing
                                 (ThemeConfiguration.PerConsoleSpacing). Visible only on a single-console
                                 library (hidden in Recent / Favorites / All Games / Collection). -->
                            <Border Name="SpacingControlPanel" Margin="8,0,0,0" Height="26"
                                    VerticalAlignment="Center" IsVisible="False"
                                    Background="{DynamicResource ToolbarRaisedFillBrush}"
                                    BorderBrush="{DynamicResource ToolbarChiselBrush}"
                                    BorderThickness="1" CornerRadius="6">
                                <Grid Width="118" ColumnDefinitions="22,*">
                                    <Border Name="SpacingHVCap" Grid.Column="0" Background="Transparent"
                                            BorderThickness="0,0,1,0" BorderBrush="{DynamicResource ToolbarChiselBrush}"
                                            Cursor="Hand" ToolTip.Tip="Click to toggle Horizontal / Vertical spacing">
                                        <TextBlock Name="SpacingHVLabel" Text="H" FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   Foreground="{DynamicResource ToolbarRaisedTextBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="0" OffsetX="0" OffsetY="1" Opacity="0.85" Color="Black"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Border>
                                    <Slider Name="SpacingSliderToolbar" Grid.Column="1" Minimum="4" Maximum="96" Value="20"
                                            Margin="6,0,8,0" VerticalAlignment="Center"
                                            Theme="{StaticResource ToolbarSpacingSlider}"
                                            ToolTip.Tip="Drag to adjust spacing for this library"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- CENTER: Library / Save States / Screenshots / Achievements tabs —
                             same float drop shadow lets the metallic segments float. -->
                        <Border Grid.Column="1" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" OffsetX="0" OffsetY="1" Opacity="0.55" Color="Black"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton Name="TabLibrary" Theme="{StaticResource TabToggleLeft}" Content="Library" IsChecked="True" Tag="Library"/>
                                <ToggleButton Name="TabSaveStates" Theme="{StaticResource TabToggleMiddle}" Content="Save States" Tag="SaveStates"/>
                                <ToggleButton Name="TabScreenshots" Theme="{StaticResource TabToggleMiddle}" Content="Screenshots" Tag="Screenshots"/>
                                <ToggleButton Name="TabAchievements" Theme="{StaticResource TabToggleRight}" Content="Achievements" Tag="Achievements"/>
                            </StackPanel>
                        </Border>

                        <!-- RIGHT: OpenEmu-style recessed search field — chisel border, dark
                             top-to-bottom gradient, and a soft downward drop shadow (upstream
                             DropShadowEffect BlurRadius 2 / down 1 / 0.6) so it reads recessed.
                             The muted count readout to its left surfaces GameCountText
                             ("Searching…" / "2 results") and only shows while a query is
                             typed (toggled in the TextChanged handler, alongside the clear
                             button — Avalonia stand-in for upstream's DataTrigger on
                             SearchBox.Text) — the per-console count already lives in the
                             sidebar badge. -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Name="SearchResultCount"
                                   Text="{Binding GameCountText}"
                                   FontFamily="{DynamicResource PrimaryFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   IsHitTestVisible="False"
                                   IsVisible="False"/>
                        <Border Name="SearchBorder" Width="180" Height="26" CornerRadius="14" Padding="10,0" VerticalAlignment="Center"
                                Background="{DynamicResource SearchFillBrush}" BorderBrush="{DynamicResource ToolbarChiselBrush}"
                                BorderThickness="1" Margin="0,0,12,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="2" OffsetX="0" OffsetY="1" Opacity="0.6" Color="Black"/>
                            </Border.Effect>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0" Text="⌕" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Name="SearchBox" Grid.Column="1" Theme="{StaticResource SearchTextBox}"
                                         Foreground="{DynamicResource TextPrimaryBrush}" CaretBrush="{DynamicResource AccentBrush}"
                                         FontFamily="{DynamicResource PrimaryFont}" FontSize="12"
                                         VerticalAlignment="Center" PlaceholderText="Search games…"/>
                                <Button Name="SearchClear" Grid.Column="2" Content="✕" Background="Transparent" BorderThickness="0"
                                        Padding="4,0" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Cursor="Hand"
                                        IsVisible="False" ToolTip.Tip="Clear search (Esc)"/>
                            </Grid>
                        </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══ LIBRARY view (grid + list + empty placeholder) ══ -->
                <Grid Name="LibraryView" Grid.Row="1">
                <!-- user-configurable background image (behind the cards) -->
                <Image Name="GridBackgroundImage" IsHitTestVisible="False" IsVisible="False"
                       Stretch="UniformToFill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                <!-- empty-library placeholder -->
                <TextBlock Text="No games yet — drag ROMs here, or click ＋ Import"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="{DynamicResource PrimaryFont}" FontSize="15"
                           Foreground="{DynamicResource TextMutedBrush}"
                           IsVisible="{Binding Games.Count, Converter={StaticResource CountIsZeroToBool}}"/>

                <!-- flat box-art grid -->
                <ListBox Name="GameGridView"
                         ItemsSource="{Binding Games}"
                         SelectionMode="Multiple"
                         Background="Transparent" BorderThickness="0"
                         Padding="{DynamicResource LibraryGridPadding}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ctl:VirtualizingWrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <!-- Game cards show NO Fluent chrome at all — no fill or accent border on hover,
                             selection, press, or focus (the card art is the only visual). Kill both the
                             background and the border for every state. -->
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected:pressed /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                        <!-- ── Selection indicator (upstream's SelectionRing, theme-accent-tied,
                             with the Linux flair: the halo breathes + a ✓ badge for unambiguous
                             multi-select). Elements live in the card template. The hidden base
                             state MUST be a style setter (not a local IsVisible attribute) —
                             local values outrank styles, so a local False would be unbeatable. ── -->
                        <Style Selector="ListBoxItem Border#SelGlow">
                            <Setter Property="IsVisible" Value="False"/>
                        </Style>
                        <Style Selector="ListBoxItem Border#SelRing">
                            <Setter Property="IsVisible" Value="False"/>
                        </Style>
                        <Style Selector="ListBoxItem Border#SelBadge">
                            <Setter Property="IsVisible" Value="False"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected Border#SelGlow">
                            <Setter Property="IsVisible" Value="True"/>
                            <Style.Animations>
                                <Animation Duration="0:0:2" IterationCount="INFINITE" Easing="SineEaseInOut">
                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.35"/></KeyFrame>
                                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.9"/></KeyFrame>
                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.35"/></KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                        <Style Selector="ListBoxItem:selected Border#SelRing">
                            <Setter Property="IsVisible" Value="True"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected Border#SelBadge">
                            <Setter Property="IsVisible" Value="True"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Game">
                            <Border Width="{DynamicResource LibraryCardWidth}" Margin="{DynamicResource LibraryCardMargin}"
                                    Background="Transparent" Cursor="Hand">
                                <Panel>
                                <StackPanel>
                                    <!-- art -->
                                    <Border CornerRadius="8" ClipToBounds="True" Background="Transparent">
                                        <Border.Height>
                                            <MultiBinding Converter="{StaticResource ConsoleToArtHeight}">
                                                <Binding Path="Console"/>
                                                <!-- Read the ANCESTOR card Border's Width (it carries the live
                                                     LibraryCardWidth DynamicResource). Binding to Self here gives
                                                     NaN — the art Border stretches and has no Width property set —
                                                     so the MultiBinding would never re-fire and the card couldn't
                                                     resize (matches upstream's AncestorLevel=1 Border binding). -->
                                                <Binding Path="Width" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                                <Binding Path="DataContext.IsMixedView" ElementName="GameGridView"/>
                                            </MultiBinding>
                                        </Border.Height>
                                        <Panel>
                                            <!-- placeholder fill (no art) -->
                                            <Border IsVisible="{Binding DisplayArtPath, Converter={StaticResource NullOrEmptyToBool}}">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"/>
                                                </Border.Background>
                                            </Border>
                                            <TextBlock Text="{Binding Title}" FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#CCFFFFFF"
                                                       TextWrapping="Wrap" TextAlignment="Center"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12"
                                                       IsVisible="{Binding DisplayArtPath, Converter={StaticResource NullOrEmptyToBool}}"/>
                                            <!-- box art — loaded async (never decodes on the UI thread)
                                                 so realizing the visible cards can't freeze the grid -->
                                            <Image ctl:AsyncImage.SourcePath="{Binding DisplayArtPath}"
                                                   Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top"
                                                   IsVisible="{Binding DisplayArtPath, Converter={StaticResource NotNullOrEmptyToBool}}"/>
                                            <!-- favorite heart -->
                                            <TextBlock Text="♥" FontSize="14" Foreground="{DynamicResource FavoriteHeartBrush}"
                                                       VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,8,8"
                                                       IsVisible="{Binding IsFavorite}"/>
                                        </Panel>
                                    </Border>
                                    <!-- title -->
                                    <TextBlock Text="{Binding Title, Converter={StaticResource SmartTitleCase}}"
                                               FontFamily="{DynamicResource PrimaryFont}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                               MaxHeight="34" Margin="4,8,4,0"/>
                                    <!-- star rating (grey base + white filled overlay) -->
                                    <Panel HorizontalAlignment="Center" Margin="0,3,0,0">
                                        <TextBlock Text="★★★★★" FontSize="11" Foreground="#FF2A2A2A"/>
                                        <TextBlock Text="{Binding Rating, Converter={StaticResource RatingToFilledStars}}"
                                                   FontSize="11" Foreground="White" HorizontalAlignment="Left"/>
                                    </Panel>
                                </StackPanel>
                                <!-- ── Selection indicator overlays (shown via :selected styles
                                     above). Sized to the ART AREA like upstream's SelectionRing
                                     (same ConsoleToArtHeight binding as the art Border), brush =
                                     LibrarySelectionBrush — the per-theme selection color the
                                     Theme tab edits. Linux flair on top of upstream's 2px ring:
                                     a breathing halo + a ✓ badge for multi-select counting. ── -->
                                <Panel VerticalAlignment="Top" IsHitTestVisible="False">
                                    <Panel.Height>
                                        <MultiBinding Converter="{StaticResource ConsoleToArtHeight}">
                                            <Binding Path="Console"/>
                                            <Binding Path="Width" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                            <Binding Path="DataContext.IsMixedView" ElementName="GameGridView"/>
                                        </MultiBinding>
                                    </Panel.Height>
                                    <Border Name="SelGlow"
                                            BorderBrush="{DynamicResource LibrarySelectionBrush}" BorderThickness="5"
                                            CornerRadius="11" Margin="-3" Opacity="0.5"/>
                                    <Border Name="SelRing"
                                            BorderBrush="{DynamicResource LibrarySelectionBrush}" BorderThickness="2"
                                            CornerRadius="8"/>
                                    <Border Name="SelBadge"
                                            Width="22" Height="22" CornerRadius="11"
                                            Background="{DynamicResource LibrarySelectionBrush}"
                                            BorderBrush="#66000000" BorderThickness="1"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0">
                                        <TextBlock Text="✓" FontSize="12" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Panel>
                                </Panel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- OpenEmu-style list view (toggled by the grid/list view buttons) -->
                <DataGrid Name="GameListView" ItemsSource="{Binding Games}"
                          IsVisible="False" AutoGenerateColumns="False" CanUserSortColumns="True"
                          CanUserResizeColumns="True" IsReadOnly="True" GridLinesVisibility="Horizontal"
                          Background="Transparent" RowBackground="Transparent"
                          HeadersVisibility="Column" SelectionMode="Extended">
                    <!-- Row chrome (upstream ListRowItemStyle): alternating fills are set in
                         LoadingRow (code-behind — Avalonia has no AlternationIndex); hover +
                         selection tint the row template's background rectangle. -->
                    <DataGrid.Styles>
                        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
                            <Setter Property="Fill" Value="#FF2A2A2A"/>
                            <Setter Property="Opacity" Value="1"/>
                        </Style>
                        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                            <Setter Property="Fill" Value="#FF2D5A8C"/>
                            <Setter Property="Opacity" Value="1"/>
                        </Style>
                        <Style Selector="DataGridRow:selected TextBlock">
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGrid.Styles>
                    <!-- Column order matches upstream: Name / Rating / Last Played / System. -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Title}" Width="380"/>
                        <DataGridTemplateColumn Header="Rating" Width="90" SortMemberPath="Rating">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:Game">
                                    <!-- Two-layer stars (upstream): 5 dim base stars with a soft
                                         shadow for the "indented" feel, filled stars overlaid. -->
                                    <Panel Margin="8,0" VerticalAlignment="Center">
                                        <TextBlock Text="★★★★★" Foreground="#33FFFFFF"
                                                   Effect="drop-shadow(0 1 1 #99000000)"/>
                                        <TextBlock Text="{Binding Rating, Converter={StaticResource RatingToFilledStars}}"
                                                   Foreground="White"/>
                                    </Panel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Last Played" Binding="{Binding LastPlayed, Converter={StaticResource LastPlayedToMediumDate}}" Width="120"/>
                        <DataGridTemplateColumn Header="System" Width="160" SortMemberPath="Console">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:Game">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,0" VerticalAlignment="Center">
                                        <Image Width="16" Height="16" Source="{Binding Console, Converter={StaticResource ConsoleTagToIcon}}"/>
                                        <TextBlock Text="{Binding Console}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Favorites grouped view (upstream FavoritesGroupedView): per-console headers +
                     wrapped art cards, populated in code-behind. Replaces grid/list while the
                     Favorites view is active. -->
                <ScrollViewer Name="FavoritesGroupedView" IsVisible="False" VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="FavoritesPanel" Margin="16,8,16,16"/>
                </ScrollViewer>
                </Grid>

                <!-- ══ SCREENSHOTS view (per-game groups, populated in code-behind) ══ -->
                <Grid Name="ScreenshotsView" Grid.Row="1" IsVisible="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,8,16,16">
                        <StackPanel>
                            <!-- Empty state -->
                            <StackPanel Name="ScreenshotsEmptyState" HorizontalAlignment="Center" Margin="0,60,0,0" IsVisible="False">
                                <TextBlock Name="ScreenshotsEmptyIcon" Text="📷" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Name="ScreenshotsEmptyHeadline" Text="Screenshots will appear here when they've been saved."
                                           FontFamily="{DynamicResource PrimaryFont}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap"/>
                                <TextBlock Name="ScreenshotsEmptyHint" Text="To take a screenshot, press Print Screen or F12 while in a game."
                                           FontFamily="{DynamicResource PrimaryFont}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Opacity="0.6" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Name="ScreenshotsPanel"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ══ SAVE STATES view (per-game groups, populated in code-behind) ══ -->
                <Grid Name="SaveStatesView" Grid.Row="1" IsVisible="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,16">
                        <StackPanel>
                            <TextBlock Name="SaveStatesEmptyText"
                                       Text="No save states yet. Press F5 or the Save State button while in a game."
                                       FontFamily="{DynamicResource PrimaryFont}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" Margin="0,60,0,0" TextWrapping="Wrap" IsVisible="False"/>
                            <StackPanel Name="SaveStatesPanel"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                    <!-- Achievements view. Sub-tabs split self-stats from
                         friend-comparison content. Profile header stays
                         global above the TabControl so identity is always
                         visible; the unconfigured placeholder takes over
                         the whole pane when RA isn't logged in. -->
                    <Grid Name="AchievementsView"
                          Grid.Row="1"
                          IsVisible="False"
                          Margin="24,18,24,24">
                        <Grid MaxWidth="1100" HorizontalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Global header (Profile card + Unconfigured placeholder) -->
                            <StackPanel Name="AchievementsHeaderPanel" Grid.Row="0">
                            <!-- A. Profile header card ─────────────────────── -->
                            <Border Name="RAProfileCard"
                                    Background="{DynamicResource BgSecondaryBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,18,20,18"
                                    Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar (64px round; placeholder until data lands) -->
                                    <Border Grid.Column="0"
                                            Width="64" Height="64"
                                            CornerRadius="32"
                                            Background="{DynamicResource BgTertiaryBrush}"
                                            ClipToBounds="True">
                                        <Image Name="RAProfileAvatar" Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Name + motto + member-since -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,16,0">
                                        <TextBlock Name="RAProfileName"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="—"/>
                                        <TextBlock Name="RAProfileMotto"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="12"
                                                   FontStyle="Italic"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Name="RAProfileMemberSince"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Points / rank cluster -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <StackPanel Margin="0,0,18,0">
                                            <TextBlock Name="RAProfilePoints"
                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Right"
                                                       Text="—"/>
                                            <TextBlock Text="POINTS"
                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Name="RAProfileSoftcore"
                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Right"
                                                       Text="—"/>
                                            <TextBlock Text="SOFTCORE"
                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            </StackPanel>
                            <!-- /Global header (closed) -->

                            <!-- Sub-tab strip: You (self stats) / Friends (social) -->
                            <TabControl Name="AchievementsSubTabs"
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        Background="Transparent"
                                        BorderThickness="0">
                                <TabItem Header="You" Name="AchievementsYouTab">
                                    <ScrollViewer
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Name="AchievementsYouPanel">

                            <!-- B. Compact 3-column row ─────────────────────
                                 Recent Unlocks (left) · Closest to Mastering
                                 (middle) · Recently Played (right). All three
                                 are scrollable mini-lists with the same fixed
                                 height so the section is bounded and the
                                 lower spotlight/featured panels stay above
                                 the fold. -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Recent Unlocks -->
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="RECENT UNLOCKS"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="2,0,0,6"/>
                                    <Border Name="RARecentCard"
                                            Background="{DynamicResource BgSecondaryBrush}"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="0">
                                        <Grid Height="300">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl Name="RARecentItems"/>
                                            </ScrollViewer>
                                            <TextBlock Name="RARecentEmpty"
                                                       Text="No recent unlocks yet. Play a RetroAchievements-supported game to start filling this feed."
                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Padding="16,0,16,0"
                                                       VerticalAlignment="Center"
                                                       IsVisible="False"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- Closest to Mastering -->
                                <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                    <TextBlock Text="CLOSEST TO MASTERING"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="2,0,0,6"/>
                                    <Border Background="{DynamicResource BgSecondaryBrush}"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="0">
                                        <Grid Height="300">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl Name="RAInProgressItems"/>
                                            </ScrollViewer>
                                            <TextBlock Name="RAInProgressEmpty"
                                                       Text="No in-progress games yet. Start a RetroAchievements set to see your closest finishes here."
                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Padding="16,0,16,0"
                                                       VerticalAlignment="Center"
                                                       IsVisible="False"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- Recently Played -->
                                <StackPanel Grid.Column="2" Margin="6,0,0,0">
                                    <TextBlock Text="RECENTLY PLAYED"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="2,0,0,6"/>
                                    <Border Background="{DynamicResource BgSecondaryBrush}"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="0">
                                        <Grid Height="300">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl Name="RARecentPlayedItems"/>
                                            </ScrollViewer>
                                            <TextBlock Name="RARecentPlayedEmpty"
                                                       Text="No recent play sessions on RetroAchievements yet."
                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Padding="16,0,16,0"
                                                       VerticalAlignment="Center"
                                                       IsVisible="False"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- C. Trophy case ──────────────────────────────── -->
                            <Grid Margin="0,18,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="TROPHY CASE"
                                           FontFamily="{DynamicResource PrimaryFont}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,0"/>
                                <StackPanel Name="RATrophyRollups"
                                            Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"/>
                            </Grid>
                            <Border Name="RATrophyCard"
                                    Background="{DynamicResource BgSecondaryBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16">
                                <StackPanel>
                                    <ItemsControl Name="RATrophyWall">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <TextBlock Name="RATrophyEmpty"
                                               Text="No awards yet. Beat or master a RetroAchievements-supported game to start filling your shelf."
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextAlignment="Center"
                                               Padding="0,12,0,12"
                                               IsVisible="False"/>
                                </StackPanel>
                            </Border>

                            <!-- D. Library Spotlight ───────────────────────────
                                 The "across all my games" cross-reference panels
                                 — the differentiator vs the RA website. Each
                                 panel hides itself when empty so the tab
                                 doesn't show empty buckets for a new user. -->
                            <TextBlock Text="ACROSS YOUR LIBRARY"
                                       FontFamily="{DynamicResource PrimaryFont}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="2,22,0,8"/>
                            <StackPanel Name="RASpotlightStack"/>

                            <!-- E. Featured / Discovery ─────────────────────────
                                 Public-facing panels: Achievement of the Week
                                 hero, recent community mastery ticker, and the
                                 site's top 10 leaderboard. All TTLs long
                                 (24h / 5min / 24h) so they're effectively free
                                 to render on tab open. -->
                            <TextBlock Text="FEATURED"
                                       FontFamily="{DynamicResource PrimaryFont}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="2,22,0,8"/>

                            <!-- Achievement of the Week hero card -->
                            <Border Name="RAOfTheWeekCard"
                                    Background="{DynamicResource BgSecondaryBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="18"
                                    Margin="0,0,0,14"
                                    IsVisible="False">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Badge with gold ring (matches mastery ring color) -->
                                    <Border Name="RAOfTheWeekBadgeOuter"
                                            Grid.Column="0"
                                            Width="84" Height="84"
                                            CornerRadius="10"
                                            BorderThickness="2"
                                            Background="{DynamicResource BgTertiaryBrush}">
                                        <Border Name="RAOfTheWeekBadgeInner"
                                                CornerRadius="8"
                                                ClipToBounds="True"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="18,2,18,0" VerticalAlignment="Center">
                                        <TextBlock Text="ACHIEVEMENT OF THE WEEK"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Name="RAOfTheWeekTitle"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Name="RAOfTheWeekGame"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Name="RAOfTheWeekDescription"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Name="RAOfTheWeekStats"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <Button Name="RAOfTheWeekPlay"
                                            Grid.Column="2"
                                            Content="▶  Play Now"
                                            Theme="{StaticResource PrefActionBtn}"
                                            Padding="20,10"
                                            VerticalAlignment="Center"
                                            IsVisible="False"/>
                                </Grid>
                            </Border>

                            <!-- Two-column row: Community Pulse (flex) + Top Ten (auto).
                                 Top Ten content is short and fixed; let it size to
                                 content so Community Pulse doesn't get pinched at
                                 narrow window widths. -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="320"/>
                                    <ColumnDefinition Width="Auto" MinWidth="240"/>
                                </Grid.ColumnDefinitions>

                                <Border Name="RACommunityPulseCard"
                                        Grid.Column="0"
                                        Background="{DynamicResource BgSecondaryBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Margin="0,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="COMMUNITY PULSE"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="16,14,16,8"/>
                                        <ItemsControl Name="RACommunityPulseItems"/>
                                        <TextBlock Name="RACommunityPulseEmpty"
                                                   Text="No recent awards reported."
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextAlignment="Center"
                                                   Padding="0,12,0,16"
                                                   IsVisible="False"/>
                                    </StackPanel>
                                </Border>

                                <Border Name="RATopTenCard"
                                        Grid.Column="1"
                                        Background="{DynamicResource BgSecondaryBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="TOP 10 SITE-WIDE"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="16,14,16,8"/>
                                        <ItemsControl Name="RATopTenItems"/>
                                        <TextBlock Name="RATopTenEmpty"
                                                   Text="Leaderboard unavailable."
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextAlignment="Center"
                                                   Padding="16,8,16,16"
                                                   IsVisible="False"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- F. Heatmap calendar (90-day activity grid) ────
                                 Each cell is one day, color intensity scaled
                                 to that day's unlock count. Hover for the
                                 count + date. Past days are persisted to
                                 ra_heatmap_daily forever (frozen) so the
                                 grid paints from disk on tab open. -->
                            <TextBlock Text="ACTIVITY"
                                       FontFamily="{DynamicResource PrimaryFont}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="2,22,0,8"/>
                            <Border Name="RAHeatmapCard"
                                    Background="{DynamicResource BgSecondaryBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14,16,14">
                                <StackPanel>
                                    <TextBlock Name="RAHeatmapCaption"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,0,0,8"/>
                                    <UniformGrid Name="RAHeatmapGrid"
                                                 Rows="7"
                                                 HorizontalAlignment="Left"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Name="RAHeatmapTotal"
                                                   Grid.Column="0"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="less"
                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <StackPanel Name="RAHeatmapLegend" Orientation="Horizontal"/>
                                            <TextBlock Text="more"
                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Logged-out / no-key placeholder for the whole tab -->
                            <Border Name="RAUnconfiguredCard"
                                    Background="{DynamicResource BgSecondaryBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="22,18,22,18"
                                    Margin="0,0,0,18"
                                    IsVisible="False">
                                <StackPanel>
                                    <TextBlock Text="🏆"
                                               FontSize="32"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,8"/>
                                    <TextBlock Text="Connect RetroAchievements to fill this tab"
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Open Preferences → RetroAchievements and add your username, password, and Web API Key. The key unlocks the per-user stats on this screen."
                                               FontFamily="{DynamicResource PrimaryFont}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <!-- ── Friends sub-tab ─────────────────────── -->
                                <TabItem Header="Friends" Name="AchievementsFriendsTab">
                                    <ScrollViewer
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Name="AchievementsFriendsPanel" Margin="0,8,0,0">

                                            <!-- Header strip: count + Add Friend button -->
                                            <Grid Margin="2,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Name="FriendsHeaderLabel"
                                                           Grid.Column="0"
                                                           Text="FRIENDS"
                                                           FontFamily="{DynamicResource PrimaryFont}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Name="FriendsImportButton"
                                                            Content="Import from RA"
                                                            Theme="{StaticResource PrefActionBtn}"
                                                            Padding="12,4"
                                                            Margin="0,0,6,0"
                                                            FontSize="11" ToolTip.Tip="Import the users you follow on retroachievements.org. New entries are added muted — tap the bell on each friend card to enable toasts."/>
                                                    <Button Name="FriendsAddButton"
                                                            Content="+ Add Friend"
                                                            Theme="{StaticResource PrefActionBtn}"
                                                            Padding="12,4"
                                                            FontSize="11"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Mini activity feed (last few unlocks across friends) -->
                                            <Border Name="FriendsActivityCard"
                                                    Background="{DynamicResource BgSecondaryBrush}"
                                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Margin="0,0,0,12"
                                                    IsVisible="False">
                                                <StackPanel>
                                                    <TextBlock Text="RECENT FRIEND ACTIVITY"
                                                               FontFamily="{DynamicResource PrimaryFont}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               Margin="16,12,16,6"/>
                                                    <ItemsControl Name="FriendsActivityItems"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Friend list / empty state -->
                                            <Border Name="FriendsListCard"
                                                    Background="{DynamicResource BgSecondaryBrush}"
                                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="0">
                                                <StackPanel>
                                                    <ItemsControl Name="FriendsListItems"/>
                                                    <TextBlock Name="FriendsListEmpty"
                                                               Text="No friends yet. Click + Add Friend above to follow another RetroAchievements user. You'll see their unlocks here as they happen."
                                                               FontFamily="{DynamicResource PrimaryFont}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Padding="24,32,24,32"
                                                               IsVisible="True"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Your Followers (Phase 7.5) — collapsible disclosure.
                                                 Lazy-fetched on first expand; shows only RA users who
                                                 follow you and aren't already in your friends list. -->
                                            <Border Name="FollowersCard"
                                                    Background="{DynamicResource BgSecondaryBrush}"
                                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Margin="0,12,0,0"
                                                    IsVisible="False">
                                                <StackPanel>
                                                    <!-- Clickable header row toggles content. -->
                                                    <Border Name="FollowersHeader"
                                                            Padding="16,12,16,12"
                                                            Cursor="Hand"
                                                            Background="Transparent">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Name="FollowersHeaderLabel"
                                                                       Grid.Column="0"
                                                                       Text="YOUR FOLLOWERS"
                                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Name="FollowersHeaderCaret"
                                                                       Grid.Column="1"
                                                                       Text="▾"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <Border Name="FollowersContent"
                                                            IsVisible="False"
                                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                            BorderThickness="0,1,0,0">
                                                        <StackPanel>
                                                            <TextBlock Name="FollowersStatus"
                                                                       Text=""
                                                                       FontFamily="{DynamicResource PrimaryFont}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Padding="16,12,16,12"
                                                                       IsVisible="False"/>
                                                            <ItemsControl Name="FollowersListItems"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <!-- Logged-out / no-key placeholder mirrors the You tab -->
                                            <Border Name="FriendsUnconfiguredCard"
                                                    Background="{DynamicResource BgSecondaryBrush}"
                                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="22,18,22,18"
                                                    Margin="0,12,0,0"
                                                    IsVisible="False">
                                                <StackPanel>
                                                    <TextBlock Text="Connect RetroAchievements to use Friends"
                                                               FontFamily="{DynamicResource PrimaryFont}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Add your username and Web API Key in Preferences → RetroAchievements to look up other users."
                                                               FontFamily="{DynamicResource PrimaryFont}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Grid>
            </Grid>
        </Grid>

        <!-- ══ STATUS / IMPORT BANNER ══ -->
        <!-- Friend/LB toast stack (A8f): bottom-right overlay, newest on top, capped at 4.
             Mirrors upstream MainWindow ToastStack. -->
        <StackPanel Name="ToastStack" ZIndex="100" HorizontalAlignment="Right"
                    VerticalAlignment="Bottom" Margin="0,0,18,18" IsHitTestVisible="True"/>
        <Border Name="StatusBanner" Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                Padding="16,8" IsVisible="{Binding IsBannerVisible}">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{Binding BannerText}" Theme="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                <ProgressBar Width="180" Height="6" Minimum="0" Maximum="100"
                             Value="{Binding BannerProgressPercent}"
                             IsVisible="{Binding IsProgressBarVisible}"
                             Foreground="{DynamicResource AccentBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
        </Border>
    </Border>
</Window>
