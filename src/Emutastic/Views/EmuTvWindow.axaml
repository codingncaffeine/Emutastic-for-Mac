<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:Emutastic.Converters"
        x:Class="Emutastic.Views.EmuTvWindow"
        x:CompileBindings="False"
        Title="EmuTV"
        WindowDecorations="None"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        Background="#FF080B12">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush GradientOrigin="50%,42%" Center="50%,42%" RadiusX="95%" RadiusY="95%">
                <GradientStop Color="#FF13203A" Offset="0"/>
                <GradientStop Color="#FF080B12" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- emuTV logo header (our own brand — safe to bundle) -->
        <Image Source="/Assets/images/emutv/logo.png"
               HorizontalAlignment="Left" VerticalAlignment="Top"
               Height="76" Margin="36,24,0,0"
               RenderOptions.BitmapInterpolationMode="HighQuality"/>

        <!-- ===== Carousel view (consoles) ===== -->
        <Grid x:Name="CarouselPanel">
            <TextBlock x:Name="SelectedConsoleLabel"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,0,0,258" FontSize="46" FontWeight="Bold"
                       Foreground="#FFFFFFFF" Opacity="0.96"/>

            <!-- Horizontal console carousel. The legacy hardcoded shell is the F8 fallback (the active
                 theme renders the live UI into ThemePreviewHost); the items panel slides via CarouselShift. -->
            <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Height="240" Margin="0,30,0,0">
                <ListBox x:Name="SystemCarousel"
                         Background="Transparent" BorderThickness="0"
                         IsHitTestVisible="False"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.RenderTransform>
                        <TranslateTransform/>
                    </ListBox.RenderTransform>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Margin" Value="20,0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            <Setter Property="RenderTransform" Value="scale(0.84)"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Opacity" Value="1"/>
                            <Setter Property="RenderTransform" Value="scale(1.1)"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="300" Height="180" CornerRadius="18"
                                    BorderBrush="#5500E5FF" BorderThickness="1.5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#22123A55" Offset="0"/>
                                        <GradientStop Color="#330A1830" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid Margin="18">
                                    <TextBlock Text="{Binding ConsoleName}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="40" FontWeight="Bold" Foreground="#FFEAF6FF"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} games'}"
                                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                               FontSize="15" Opacity="0.7" Foreground="#FFBFEFFF"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <TextBlock x:Name="StatusLabel"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="22" Opacity="0.7" Foreground="#FF8FE3FF"
                       Text="Loading library…"/>
        </Grid>

        <!-- ===== Gamelist view: list (left) + TV & save-states (right) ===== -->
        <Grid x:Name="GameListPanel" IsVisible="False" Margin="0,114,0,92">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42*"/>
                <ColumnDefinition Width="58*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: game list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="GameListHeader" Grid.Row="0"
                           FontSize="32" FontWeight="Bold" Margin="40,0,0,12"
                           Foreground="#FFEAF6FF"/>
                <ListBox x:Name="GameList" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         Margin="28,0,12,0" IsHitTestVisible="False"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="Margin" Value="0,3"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#2200E5FF"/>
                            <Setter Property="BorderBrush" Value="#7000E5FF"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="58">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="78"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#22000000" CornerRadius="6">
                                    <Image Source="{Binding DisplayArtPath, Converter={StaticResource PathToImage}}"
                                           Stretch="Uniform" RenderOptions.BitmapInterpolationMode="LowQuality"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Title}"
                                           VerticalAlignment="Center" Margin="16,0,0,0"
                                           FontSize="20" Foreground="#FFEAF6FF"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Right: TV preview (top) + save-state browser (bottom) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="196"/>
                </Grid.RowDefinitions>

                <!-- TV preview -->
                <Viewbox Grid.Row="0" Stretch="Uniform" Margin="10,6,40,2">
                    <Canvas Width="1408" Height="768">
                        <!-- Screen content sits BEHIND the TV and shows through the
                             transparent cutout (rect from alpha flood-fill). -->
                        <Border Canvas.Left="445" Canvas.Top="286" Width="415" Height="322"
                                ClipToBounds="True" Background="#FF050608">
                            <Grid>
                                <!-- Fallback: the game's 2D cover, scaled to fit. -->
                                <Image x:Name="TvFallbackImage" Stretch="Uniform"
                                       Source="{Binding #GameList.SelectedItem.CoverArtPath,
                                                Converter={StaticResource PathToImage}}"/>
                                <!-- Video layer (VLC frames → WriteableBitmap). -->
                                <Image x:Name="TvVideoImage" Stretch="UniformToFill" IsVisible="False"/>
                                <!-- "Please Stand By" while auto-downloading a snap. -->
                                <Image x:Name="TvStandByImage" Stretch="UniformToFill" IsVisible="False"
                                       Source="/Assets/images/emutv/please_stand_by2.png"
                                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
                            </Grid>
                        </Border>
                        <!-- TV frame ON TOP; transparent screen reveals the layer behind. -->
                        <Image Source="/Assets/images/emutv/proper_tv2.png"
                               Width="1408" Height="768" Canvas.Left="0" Canvas.Top="0"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    </Canvas>
                </Viewbox>

                <!-- Save-state browser: VCR-tape label (left) + saves carousel (right).
                     Dimmed when the game list has focus; full when focused (Right). -->
                <Grid Grid.Row="1" x:Name="SaveRow" Margin="10,2,40,6" Opacity="0.5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Source="/Assets/images/emutv/save_states.png"
                           Width="208" Stretch="Uniform"
                           HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,14,0"
                           RenderOptions.BitmapInterpolationMode="HighQuality"/>

                    <Grid Grid.Column="1" x:Name="SaveListHome">
                        <TextBlock x:Name="NoSavesLabel" Text="No save states yet"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                   FontSize="18" Opacity="0.6" Foreground="#FF8FE3FF"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center" Height="160">
                            <ListBox x:Name="SaveList"
                                     Background="Transparent" BorderThickness="0"
                                     IsHitTestVisible="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.RenderTransform>
                                    <TranslateTransform/>
                                </ListBox.RenderTransform>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Margin" Value="10,0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Opacity" Value="0.55"/>
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                        <Setter Property="RenderTransform" Value="scale(0.9)"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="RenderTransform" Value="scale(1.0)"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="232" Height="150" CornerRadius="10"
                                                Background="#22000000" BorderBrush="#5500E5FF" BorderThickness="1.5">
                                            <Grid>
                                                <Image Source="{Binding ScreenshotPath, Converter={StaticResource PathToImage}}"
                                                       Stretch="UniformToFill"/>
                                                <Border VerticalAlignment="Bottom" Background="#99000000" Padding="8,3">
                                                    <TextBlock Foreground="#FFEAF6FF" FontSize="13"
                                                               Text="{Binding RelativeTime}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- Hint bar (text updated per view) -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,40" Padding="24,11"
                CornerRadius="24" Background="#2200E5FF" BorderBrush="#5500E5FF" BorderThickness="1">
            <TextBlock x:Name="HintLabel" FontSize="17" FontWeight="SemiBold"
                       Foreground="#FFC8F2FF" Text="Navigate    A  Open    B  Back"/>
        </Border>

        <!-- Preview tag -->
        <TextBlock Text="EmuTV — preview build"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,28,36,0" FontSize="13" Opacity="0.45"
                   Foreground="#FF8FE3FF"/>

        <!-- The active theme renders here AS the live UI (always on; F8 toggles it off for debug).
             A bordered host fills an opaque backdrop behind the rendered theme so the legacy shell
             never bleeds through a transparent area of a theme. -->
        <Border x:Name="ThemePreviewHost" IsVisible="False" Background="#FF05070C"/>

        <!-- ===== Unified theme browser (Y / T): installed + downloadable catalog in one list ===== -->
        <Border x:Name="ThemeBrowser" IsVisible="False" Background="#F4070B14">
            <Grid Margin="72,48,72,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="THEMES" FontSize="40" FontWeight="Bold"
                           Foreground="#FFEAF6FF" Margin="2,0,0,18"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="60*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="ThemeBrowserList" Grid.Column="0" Margin="0,0,28,0"
                             Background="Transparent" BorderThickness="0" IsHitTestVisible="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="14,9"/>
                                <Setter Property="Margin" Value="0,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="#2200E5FF"/>
                                <Setter Property="BorderBrush" Value="#7000E5FF"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="21" Foreground="#FFEAF6FF"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding AuthorLine}" FontSize="12.5" Opacity="0.6"
                                                   Foreground="#FFBFEFFF" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" VerticalAlignment="Center" CornerRadius="9"
                                            Padding="9,2" Margin="10,0,0,0" Background="{Binding StatusBrush}">
                                        <TextBlock Text="{Binding StatusText}" FontSize="11.5" FontWeight="SemiBold"
                                                   Foreground="#FF06121C"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#22000000" CornerRadius="10" ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="No preview" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.4" Foreground="#FF8FE3FF" FontSize="18"/>
                                <Image x:Name="ThemeBrowserPreview" Stretch="Uniform" Margin="6"
                                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="1" Margin="2,14,0,0">
                            <TextBlock x:Name="ThemeBrowserName" FontSize="26" FontWeight="Bold" Foreground="#FFEAF6FF"/>
                            <TextBlock x:Name="ThemeBrowserMeta" FontSize="15" Opacity="0.75" Foreground="#FFC8F2FF"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <StackPanel x:Name="ThemeBrowserAxes" Margin="0,12,0,0" IsVisible="False">
                                <TextBlock x:Name="ThemeBrowserColors" FontSize="18" FontWeight="SemiBold"
                                           Foreground="#FFEAF6FF" Margin="0,2,0,0"/>
                                <TextBlock x:Name="ThemeBrowserVariant" FontSize="18" FontWeight="SemiBold"
                                           Foreground="#FFEAF6FF" Margin="0,6,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <TextBlock Grid.Row="2" x:Name="ThemeBrowserHint" Margin="2,16,0,0"
                           FontSize="17" FontWeight="SemiBold" Foreground="#FFC8F2FF"
                           Text="▲ ▼  Browse      ◀ ▶  Color      L1 R1  Variant      A  Apply / Download      B  Close"/>
            </Grid>
        </Border>

        <!-- ===== Save-state selector: self-contained overlay over ANY theme (Start in the game
             list). The save carousel is reparented in here when opened, so it works regardless of
             where the active theme puts things. ===== -->
        <Border x:Name="SaveOverlay" IsVisible="False" Background="#E8060A12">
            <Grid VerticalAlignment="Center" MaxWidth="1500" Margin="60,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Image Grid.Row="0" x:Name="SaveOverlayCassette" Height="155" Stretch="Uniform"
                       HorizontalAlignment="Center" Margin="0,0,0,2"
                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
                <TextBlock Grid.Row="1" x:Name="SaveOverlaySubtitle" Text="" FontSize="19" Opacity="0.7"
                           Foreground="#FFBFEFFF" HorizontalAlignment="Center" Margin="0,4,0,22"/>
                <Grid Grid.Row="2" x:Name="SaveOverlayHost">
                    <TextBlock x:Name="SaveOverlayEmpty" Text="No save states yet for this game"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="20" Opacity="0.55" Foreground="#FF8FE3FF"/>
                </Grid>
                <TextBlock Grid.Row="3" Text="◀ ▶  Browse         A  Load         B  Close"
                           FontSize="17" FontWeight="SemiBold" Foreground="#FFC8F2FF"
                           HorizontalAlignment="Center" Margin="0,22,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
