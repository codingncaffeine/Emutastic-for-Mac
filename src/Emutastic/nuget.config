<?xml version="1.0" encoding="utf-8"?>
<!--
  macOS port: restore from nuget.org only. The Linux port added a local feed of a
  vendored Avalonia 12.1.999 (PR #20926, X11 drag-and-drop). macOS uses released
  Avalonia from nuget.org instead — see the Avalonia PackageReferences in the csproj.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
